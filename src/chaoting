def cmd_lesson(args):
    """Record a lesson learned (qianche) for a zouzhe or agent role.

    Usage:
      chaoting lesson <zouzhe_id> '<lesson>'            # infer role from zouzhe
      chaoting lesson <zouzhe_id> '<lesson>' --role <role>  # explicit role
      chaoting lesson --global '<lesson>' --role <role>     # no zouzhe binding
    """
    if len(args) < 2:
        out({
            "ok": False,
            "error": "usage: chaoting lesson <zouzhe_id|--global> '<lesson>' [--role <role>]",
        }, ok=False)

    # Parse --role override
    role_override = None
    filtered_args = []
    i = 0
    while i < len(args):
        if args[i] == "--role" and i + 1 < len(args):
            role_override = args[i + 1]
            i += 2
        else:
            filtered_args.append(args[i])
            i += 1

    is_global = filtered_args[0] == "--global"
    zid = None if is_global else filtered_args[0]
    lesson = filtered_args[1] if len(filtered_args) > 1 else None

    if not lesson:
        out({"ok": False, "error": "lesson text is required"}, ok=False)

    db = get_db()

    # Determine agent_role
    agent_role = role_override
    if not agent_role and zid:
        row = db.execute("SELECT assigned_agent FROM zouzhe WHERE id = ?", (zid,)).fetchone()
        if row and row["assigned_agent"]:
            agent_role = row["assigned_agent"]
    if not agent_role:
        # Fallback: use OPENCLAW_AGENT_ID env
        agent_role = os.environ.get("OPENCLAW_AGENT_ID", "unknown")

    db.execute(
        "INSERT INTO qianche (agent_role, zouzhe_id, lesson) VALUES (?, ?, ?)",
        (agent_role, zid, lesson),
    )
    db.commit()
    db.close()

    out({"ok": True, "agent_role": agent_role, "zouzhe_id": zid, "lesson": lesson[:100]})


def cmd_vote(args):
    # Parse: chaoting vote ZZ-xxx go/nogo 'reason' --as jishi_tech
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting vote <zouzhe_id> <go|nogo> '<reason>' --as <jishi_id>"}, ok=False)

    zid = args[0]
    vote = args[1]
    reason = args[2] if len(args) > 2 else ""

    if vote not in ("go", "nogo"):
        out({"ok": False, "error": "vote must be 'go' or 'nogo'"}, ok=False)

    # Parse --as parameter
    jishi_id = None
    if "--as" in args:
        idx = args.index("--as")
        if idx + 1 < len(args):
            jishi_id = args[idx + 1]
    if not jishi_id:
        out({"ok": False, "error": "--as <jishi_id> is required"}, ok=False)

    agent_id = os.environ.get("OPENCLAW_AGENT_ID", "unknown")

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        zouzhe = db.execute(
            "SELECT id, revise_count, discord_thread_id FROM zouzhe WHERE id = ? AND state = 'reviewing'",
            (zid,),
        ).fetchone()

        if not zouzhe:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "zouzhe not in reviewing state"}, ok=False)

        current_round = (zouzhe["revise_count"] or 0) + 1

        cursor = db.execute(
            "INSERT OR IGNORE INTO toupiao (zouzhe_id, round, jishi_id, agent_id, vote, reason) "
            "VALUES (?, ?, ?, ?, ?, ?)",
            (zid, current_round, jishi_id, agent_id, vote, reason),
        )

        if cursor.rowcount == 0:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "already voted this round"}, ok=False)

        db.execute("COMMIT")
        thread_id = zouzhe["discord_thread_id"]
        db.close()
        zouzhe_log(zid, jishi_id, "VOTE",
                   vote.upper(),
                   jishi=jishi_id,
                   round=current_round,
                   reason=reason)
        send_discord(zid, _fmt_vote_thread(zid, jishi_id, vote, reason, current_round), thread_id=thread_id)
        out({"ok": True, "action": "vote", "zouzhe_id": zid, "vote": vote,
             "jishi_id": jishi_id, "round": current_round})
    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


