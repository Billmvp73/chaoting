def cmd_teams(args):
    """
    Agent Teams 文件哨兵管理命令。

    子命令：
      sentinel-write  <zouzhe_id> <teammate_id> [--status done|failed] [--output <text>] [--error <text>]
      sentinel-read   <zouzhe_id> <teammate_id>
      sentinel-status <zouzhe_id> [--teammates t1 t2 ...]
      sentinel-wait   <zouzhe_id> <t1> [t2 ...] [--timeout N] [--poll N]
      sentinel-list   <zouzhe_id>
      sentinel-cleanup <zouzhe_id>
      run             <zouzhe_id> -- Run an Agent Teams task via claude --print
    """
    from sentinel import (
        SentinelWatcher, write_sentinel, read_sentinel,
        list_sentinels, cleanup_sentinels,
        SENTINEL_DONE, SENTINEL_FAILED,
    )
    import argparse

    if not args or args[0] in ("-h", "--help"):
        out({"ok": False, "error": (
            "usage: chaoting teams <subcmd> ...\n"
            "subcmds: sentinel-write sentinel-read sentinel-status "
            "sentinel-wait sentinel-list sentinel-cleanup run"
        )}, ok=False)

    subcmd = args[0]
    rest = args[1:]

    # ── sentinel-write ──
    if subcmd == "sentinel-write":
        p = argparse.ArgumentParser(prog="chaoting teams sentinel-write")
        p.add_argument("zouzhe_id")
        p.add_argument("teammate_id")
        p.add_argument("--status", default="done")
        p.add_argument("--output", default=None)
        p.add_argument("--error", default=None)
        a = p.parse_args(rest)
        path = write_sentinel(
            CHAOTING_DIR, a.zouzhe_id, a.teammate_id,
            status=a.status, output=a.output, error=a.error,
        )
        out({"ok": True, "path": str(path), "zouzhe_id": a.zouzhe_id,
             "teammate_id": a.teammate_id, "status": a.status})

    # ── sentinel-read ──
    elif subcmd == "sentinel-read":
        p = argparse.ArgumentParser(prog="chaoting teams sentinel-read")
        p.add_argument("zouzhe_id")
        p.add_argument("teammate_id")
        a = p.parse_args(rest)
        data = read_sentinel(CHAOTING_DATA_DIR, a.zouzhe_id, a.teammate_id)
        if data:
            out({"ok": True, **data})
        else:
            out({"ok": False, "error": "sentinel not found",
                 "zouzhe_id": a.zouzhe_id, "teammate_id": a.teammate_id}, ok=False)

    # ── sentinel-status ──
    elif subcmd == "sentinel-status":
        p = argparse.ArgumentParser(prog="chaoting teams sentinel-status")
        p.add_argument("zouzhe_id")
        p.add_argument("--teammates", nargs="*", default=None)
        a = p.parse_args(rest)
        teammate_ids = a.teammates or list_sentinels(CHAOTING_DATA_DIR, a.zouzhe_id)
        watcher = SentinelWatcher(a.zouzhe_id, CHAOTING_DATA_DIR)
        watcher.register(teammate_ids)
        statuses = watcher.status()
        summary = {
            "zouzhe_id": a.zouzhe_id,
            "total": len(teammate_ids),
            "done": sum(1 for d in statuses.values() if d and d.get("status") == SENTINEL_DONE),
            "failed": sum(1 for d in statuses.values() if d and d.get("status") == SENTINEL_FAILED),
            "pending": sum(1 for d in statuses.values() if d is None),
            "details": {t: (d.get("status") if d else "pending") for t, d in statuses.items()},
        }
        out({"ok": True, **summary})

    # ── sentinel-wait ──
    elif subcmd == "sentinel-wait":
        p = argparse.ArgumentParser(prog="chaoting teams sentinel-wait")
        p.add_argument("zouzhe_id")
        p.add_argument("teammates", nargs="+")
        p.add_argument("--timeout", type=int, default=600)
        p.add_argument("--poll", type=float, default=2.0)
        a = p.parse_args(rest)
        watcher = SentinelWatcher(a.zouzhe_id, CHAOTING_DATA_DIR)
        watcher.register(a.teammates)
        result = watcher.wait_all(timeout=a.timeout, poll_interval=a.poll)
        out({"ok": result["status"] == "complete", **result})

    # ── sentinel-list ──
    elif subcmd == "sentinel-list":
        p = argparse.ArgumentParser(prog="chaoting teams sentinel-list")
        p.add_argument("zouzhe_id")
        a = p.parse_args(rest)
        items = list_sentinels(CHAOTING_DATA_DIR, a.zouzhe_id)
        out({"ok": True, "zouzhe_id": a.zouzhe_id, "sentinels": items})

    # ── sentinel-cleanup ──
    elif subcmd == "sentinel-cleanup":
        p = argparse.ArgumentParser(prog="chaoting teams sentinel-cleanup")
        p.add_argument("zouzhe_id")
        a = p.parse_args(rest)
        n = cleanup_sentinels(CHAOTING_DATA_DIR, a.zouzhe_id)
        out({"ok": True, "zouzhe_id": a.zouzhe_id, "deleted": n})

    # ── run ──
    elif subcmd == "run":
        p = argparse.ArgumentParser(prog="chaoting teams run")
        p.add_argument("zouzhe_id")
        p.add_argument("--prompt", required=True, help="Task prompt for the lead agent")
        p.add_argument("--max-turns", type=int, default=80)
        p.add_argument("--timeout", type=int, default=600)
        p.add_argument("--cwd", default=None)
        a = p.parse_args(rest)

        env = dict(os.environ)
        env["CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"] = "1"
        env["CHAOTING_DIR"] = CHAOTING_DIR

        claude_cmd = ["claude", "--print", "--dangerously-skip-permissions",
                      "--max-turns", str(a.max_turns), a.prompt]

        import subprocess as sp
        run_cwd = a.cwd or CHAOTING_DIR
        try:
            result = sp.run(
                claude_cmd,
                env=env,
                cwd=run_cwd,
                capture_output=True,
                text=True,
                timeout=a.timeout,
            )
            out({
                "ok": result.returncode == 0,
                "zouzhe_id": a.zouzhe_id,
                "returncode": result.returncode,
                "stdout": result.stdout[-3000:] if result.stdout else "",
                "stderr": result.stderr[-1000:] if result.stderr else "",
            }, ok=result.returncode == 0)
        except sp.TimeoutExpired:
            out({"ok": False, "error": f"timeout after {a.timeout}s",
                 "zouzhe_id": a.zouzhe_id}, ok=False)
        except Exception as exc:
            out({"ok": False, "error": str(exc), "zouzhe_id": a.zouzhe_id}, ok=False)

    # ── metrics (V0.4) ──
    elif subcmd == "metrics":
        p = argparse.ArgumentParser(prog="chaoting teams metrics")
        p.add_argument("zouzhe_id")
        p.add_argument("--teammates", nargs="*", default=None)
        a = p.parse_args(rest)
        from sentinel import SentinelWatcher, list_sentinels
        teammate_ids = a.teammates or list_sentinels(CHAOTING_DATA_DIR, a.zouzhe_id)
        watcher = SentinelWatcher(a.zouzhe_id, CHAOTING_DATA_DIR)
        watcher.register(teammate_ids)
        m = watcher.get_metrics()
        out({"ok": True, **m})

    # ── logs --follow (V0.4) ──
    elif subcmd == "logs":
        p = argparse.ArgumentParser(prog="chaoting teams logs")
        p.add_argument("zouzhe_id")
        p.add_argument("--teammates", nargs="*", default=None)
        p.add_argument("--follow", action="store_true",
                       help="Keep polling until all done/timeout")
        p.add_argument("--interval", type=float, default=2.0)
        p.add_argument("--timeout", type=int, default=600)
        a = p.parse_args(rest)
        from sentinel import SentinelWatcher, list_sentinels, SENTINEL_DONE, SENTINEL_FAILED, SENTINEL_TIMEOUT
        teammate_ids = a.teammates or list_sentinels(CHAOTING_DATA_DIR, a.zouzhe_id)
        watcher = SentinelWatcher(a.zouzhe_id, CHAOTING_DATA_DIR)
        watcher.register(teammate_ids)

        if not a.follow:
            line = watcher.progress_summary()
            print(f"[{a.zouzhe_id}] {line}")
        else:
            start = __import__("time").time()
            import time as _time
            while True:
                line = watcher.progress_summary()
                ts = __import__("datetime").datetime.now().strftime("%H:%M:%S")
                print(f"[{ts}] {a.zouzhe_id}: {line}")
                statuses = watcher.status()
                if all(
                    d is not None and d.get("status") in (SENTINEL_DONE, SENTINEL_FAILED, SENTINEL_TIMEOUT)
                    for d in statuses.values()
                ):
                    print(f"[{ts}] All done.")
                    break
                if a.timeout > 0 and _time.time() - start >= a.timeout:
                    print(f"[{ts}] Logs timeout after {a.timeout}s")
                    break
                _time.sleep(a.interval)

    # ── generate-prompt (V0.4) ──
    elif subcmd == "generate-prompt":
        p = argparse.ArgumentParser(prog="chaoting teams generate-prompt")
        p.add_argument("zouzhe_id")
        p.add_argument("--workflow", choices=["parallel", "iterative"], required=True)
        p.add_argument("--task", required=True, help="Base task description")
        p.add_argument("--criteria", default="Check: correctness, error handling, code quality")
        p.add_argument("--max-rounds", type=int, default=3)
        p.add_argument("--quality-threshold", type=int, default=12)
        a = p.parse_args(rest)
        from teams import generate_lead_prompt
        prompt = generate_lead_prompt(
            workflow=a.workflow,
            zouzhe_id=a.zouzhe_id,
            base_task=a.task,
            review_criteria=a.criteria,
            chaoting_dir=CHAOTING_DIR,
            max_rounds=a.max_rounds,
            quality_threshold=a.quality_threshold,
        )
        # Output raw prompt (not JSON), for direct use in shell scripts
        print(prompt)

    else:
        out({"ok": False, "error": f"unknown subcommand: {subcmd}"}, ok=False)


COMMANDS = {
    "new": cmd_new,
    "list": cmd_list,
    "status": cmd_status,
    "revise": cmd_revise,
    "resume": cmd_resume,
    "decide": cmd_decide,
    "pull": cmd_pull,
    "plan": cmd_plan,
    "progress": cmd_progress,
    "done": cmd_done,
    "fail": cmd_fail,
    "push-for-review": cmd_push_for_review,
    "yushi-approve": cmd_yushi_approve,
    "yushi-nogo": cmd_yushi_nogo,
    "logs": cmd_logs,
    "health": cmd_health,
    "context": cmd_context,
    "lesson": cmd_lesson,
    "vote": cmd_vote,
    "notify": cmd_notify,
    "teams": cmd_teams,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        cmds = ", ".join(COMMANDS.keys())
        out({"ok": False, "error": f"usage: chaoting <{cmds}> [args...]"}, ok=False)

    cmd = sys.argv[1]
    COMMANDS[cmd](sys.argv[2:])


if __name__ == "__main__":
    main()
