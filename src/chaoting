def cmd_logs(args):
    """Query service logs via journalctl.

    Usage: chaoting logs <service> [--tail N] [--grep pattern] [--since Xs|Xm|Xh]

    Examples:
        chaoting logs chaoting-dispatcher-.themachine
        chaoting logs beebot --tail 50
        chaoting logs themachine-gateway --grep "ERROR" --since 1h
        chaoting logs chaoting-dispatcher-.themachine --since 30m --tail 100
    """
    if len(args) < 1:
        out({
            "ok": False,
            "error": "usage: chaoting logs <service> [--tail N] [--grep pattern] [--since Xs|Xm|Xh]",
        }, ok=False)

    service = args[0]
    tail = None
    grep = None
    since = None

    i = 1
    while i < len(args):
        if args[i] == "--tail" and i + 1 < len(args):
            try:
                tail = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--tail must be an integer"}, ok=False)
            i += 2
        elif args[i] == "--grep" and i + 1 < len(args):
            grep = args[i + 1]
            i += 2
        elif args[i] == "--since" and i + 1 < len(args):
            since = args[i + 1]
            i += 2
        else:
            i += 1

    # Build journalctl command
    cmd = ["journalctl", "--user", "-u", service, "--no-pager"]

    if tail is not None:
        cmd += ["-n", str(tail)]

    if grep:
        cmd += ["-g", grep]

    if since:
        # Convert Xs/Xm/Xh to journalctl --since format
        since_arg = since
        if since.endswith("s") and since[:-1].isdigit():
            since_arg = f"{since[:-1]} seconds ago"
        elif since.endswith("m") and since[:-1].isdigit():
            since_arg = f"{since[:-1]} minutes ago"
        elif since.endswith("h") and since[:-1].isdigit():
            since_arg = f"{since[:-1]} hours ago"
        cmd += ["--since", since_arg]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        lines = result.stdout.splitlines()
        out({
            "ok": True,
            "service": service,
            "line_count": len(lines),
            "logs": result.stdout,
            "filters": {
                "tail": tail,
                "grep": grep,
                "since": since,
            },
        })
    except subprocess.TimeoutExpired:
        out({"ok": False, "error": "journalctl timed out after 15s"}, ok=False)
    except FileNotFoundError:
        out({"ok": False, "error": "journalctl not found — not a systemd host"}, ok=False)
    except Exception as e:
        out({"ok": False, "error": str(e)}, ok=False)


def _check_service_health(service, endpoint=None):
    """Internal helper: check service health via systemctl + optional HTTP endpoint.

    Returns a dict: {active, healthy, details, endpoint_ok (if endpoint provided)}
    """
    details = []

    # Check systemctl --user is-active
    try:
        result = subprocess.run(
            ["systemctl", "--user", "is-active", service],
            capture_output=True, text=True, timeout=10,
        )
        active_status = result.stdout.strip()
        active = active_status == "active"
        details.append(f"systemctl status: {active_status}")
    except subprocess.TimeoutExpired:
        active = False
        details.append("systemctl check timed out")
    except FileNotFoundError:
        active = False
        details.append("systemctl not found")
    except Exception as e:
        active = False
        details.append(f"systemctl error: {e}")

    healthy = active
    endpoint_ok = None

    # Optional HTTP health endpoint check
    if endpoint:
        try:
            ep_result = subprocess.run(
                ["curl", "-sf", "--max-time", "5", endpoint],
                capture_output=True, text=True, timeout=10,
            )
            endpoint_ok = ep_result.returncode == 0
            if endpoint_ok:
                details.append(f"endpoint {endpoint}: OK")
            else:
                details.append(f"endpoint {endpoint}: FAILED (exit {ep_result.returncode})")
            healthy = healthy and endpoint_ok
        except subprocess.TimeoutExpired:
            endpoint_ok = False
            healthy = False
            details.append(f"endpoint {endpoint}: timed out")
        except FileNotFoundError:
            endpoint_ok = False
            details.append("curl not found — skipping endpoint check")
        except Exception as e:
            endpoint_ok = False
            details.append(f"endpoint check error: {e}")

    result_dict = {
        "service": service,
        "active": active,
        "healthy": healthy,
        "details": details,
    }
    if endpoint is not None:
        result_dict["endpoint_ok"] = endpoint_ok

    return result_dict


def cmd_health(args):
    """Check service health via systemctl + optional HTTP endpoint.

    Usage: chaoting health <service> [--endpoint URL]

    Returns JSON: {service, active, healthy, details, endpoint_ok?}

    Examples:
        chaoting health chaoting-dispatcher-.themachine
        chaoting health beebot --endpoint http://localhost:8080/health
    """
    if len(args) < 1:
        out({
            "ok": False,
