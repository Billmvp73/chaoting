# ── workspace 隔离支持（ZZ-20260310-016）──
# Priority: 1) CHAOTING_WORKSPACE env  2) script path inside .chaoting/  3) CWD walk-up
_WORKSPACE = os.environ.get("CHAOTING_WORKSPACE", "")
if not _WORKSPACE:
    # Auto-detect from script location: {ws}/.chaoting/src/chaoting
    _script_parent = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
