def _fmt_done_thread(zid: str, agent: str, output: str, summary: str) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    prefix = _dept_prefix(agent)
    out_lines = (output or "").strip()[:600]
    return (
        f"{prefix} 任务完成\n\n"
        f"奏折：`{zid}`\n"
        f"完成时间：{ts}\n\n"
        f"**【工作内容】**\n{out_lines}\n\n"
        f"**【输出概述】**\n{summary or '(无摘要)'}\n\n"
        f"如有问题，请在此 Thread 中讨论。"
    )


def _fmt_fail_thread(zid: str, agent: str, reason: str) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    prefix = _dept_prefix(agent)
    return (
        f"{prefix} 任务失败\n\n"
        f"奏折：`{zid}`\n"
        f"失败时间：{ts}\n\n"
        f"**【失败原因】**\n{reason or '(未说明)'}\n\n"
        f"请在此 Thread 中讨论处理方案。"
    )


def _fmt_plan_thread(zid: str, target_agent: str, next_state: str, plan_raw: str = None) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    if next_state == "reviewing":
        action = "计划已提交，进入门下省审核"
        detail = f"• 负责部门：{target_agent}\n• 下一状态：reviewing（等待给事中投票）"
    else:
        action = "计划已提交，直接进入执行（免审）"
        detail = f"• 负责部门：{target_agent}\n• 下一状态：executing"
    plan_section = ""
    if plan_raw:
        try:
            plan = json.loads(plan_raw)
            parts = []
            if plan.get("steps"):
                steps_text = "\n".join(f"  {i+1}. {s}" for i, s in enumerate(plan["steps"]))
                parts.append(f"**执行步骤：**\n{steps_text}")
            if plan.get("acceptance_criteria"):
                parts.append(f"**验收标准：** {plan['acceptance_criteria']}")
            if parts:
                plan_section = "\n\n" + "\n".join(parts)
        except (json.JSONDecodeError, TypeError):
            pass
    return (
        f"【中书省】📝 规划方案已提出\n\n"
        f"奏折：`{zid}`\n"
        f"提交时间：{ts}\n\n"
        f"{action}\n{detail}{plan_section}"
    )


def _fmt_vote_thread(zid: str, jishi_id: str, vote: str, reason: str, round_num: int) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    prefix = _dept_prefix(jishi_id)
    symbol = "GO ✅" if vote == "go" else "NOGO ❌"
    reason_line = f"\n\n**【审查意见】**\n{reason}" if reason else ""
    return (
        f"{prefix} 审查完成\n\n"
        f"奏折：`{zid}`\n"
        f"投票：{symbol}\n"
        f"轮次：第 {round_num} 轮\n"
        f"时间：{ts}"
        f"{reason_line}"
    )


def _fmt_revise_thread(zid: str, caller: str, reason: str, count: int, target_state: str) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    target_label = "重新规划（revising）" if target_state == "revising" else "重新执行（executing）"
    prefix = _dept_prefix(caller)
    return (
        f"{prefix} 奏折退回返工\n\n"
        f"奏折：`{zid}`\n"
        f"第 {count} 次返工 → {target_label}\n"
        f"时间：{ts}\n\n"
        f"**【返工原因】**\n{reason}"
    )

def out(data, ok=True):
    code = 0 if ok else 1
    print(json.dumps(data, ensure_ascii=False))
    sys.exit(code)


def cmd_new(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting new '<title>' ['<description>'] [--review N] [--priority normal|critical] [--timeout 600] [--thread-id DISCORD_THREAD_ID]"}, ok=False)

    title = args[0]

    # Validate title
    stripped_title = title.strip()
    if not stripped_title:
        out({"ok": False, "error": "Invalid title: title cannot be empty"}, ok=False)
    if stripped_title.startswith("--"):
        out({"ok": False, "error": 'Invalid title: title cannot start with "--" (possible misuse as a flag)'}, ok=False)
    if len(stripped_title) < 2:
        out({"ok": False, "error": "Invalid title: title must be at least 2 characters"}, ok=False)

    # description is optional positional arg (before any -- flags)
    description = ""
    idx_start = 1
    if len(args) > 1 and not args[1].startswith("--"):
        description = args[1]
        idx_start = 2

    # Parse optional flags
    review_required = 2  # default: tech + risk review
    priority = "normal"
    timeout_sec = 600
    discord_thread_id = None

    i = idx_start
    while i < len(args):
        if args[i] == "--review" and i + 1 < len(args):
            try:
                review_required = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--review must be an integer (0-3)"}, ok=False)
            i += 2
        elif args[i] == "--priority" and i + 1 < len(args):
            priority = args[i + 1]
            i += 2
        elif args[i] == "--timeout" and i + 1 < len(args):
            try:
                timeout_sec = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--timeout must be an integer"}, ok=False)
            i += 2
        elif args[i] == "--thread-id" and i + 1 < len(args):
            discord_thread_id = args[i + 1]
            i += 2
        else:
            i += 1

    today = datetime.now(timezone.utc).strftime("%Y%m%d")
    prefix = f"ZZ-{today}-"

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        # Concurrency-safe ID generation via MAX in transaction
        row = db.execute(
            "SELECT MAX(id) AS max_id FROM zouzhe WHERE id LIKE ?",
            (f"{prefix}%",),
        ).fetchone()

        if row["max_id"]:
            last_num = int(row["max_id"][-3:])
            next_num = last_num + 1
        else:
            next_num = 1

        new_id = f"{prefix}{next_num:03d}"

        # Validate discord_thread_id uniqueness: prevent two active zouzhe from sharing a thread
        if discord_thread_id:
            conflict = db.execute(
                "SELECT id FROM zouzhe WHERE discord_thread_id = ? "
                "AND state NOT IN ('done', 'failed', 'timeout')",
                (discord_thread_id,),
            ).fetchone()
            if conflict:
                db.execute("ROLLBACK")
                db.close()
                out({
                    "ok": False,
                    "error": f"discord_thread_id {discord_thread_id} is already used by active zouzhe {conflict['id']}. "
                             f"Each active zouzhe must have a unique thread."
                }, ok=False)

        db.execute(
            "INSERT INTO zouzhe "
            "(id, title, description, state, priority, timeout_sec, review_required, revise_count, discord_thread_id) "
            "VALUES (?, ?, ?, 'created', ?, ?, ?, 0, ?)",
            (new_id, title, description, priority, timeout_sec, review_required, discord_thread_id),
        )

        db.execute("COMMIT")
        db.close()

        # Audit log: record creation in caller's log file
        caller = os.environ.get("OPENCLAW_AGENT_ID", "silijian")
        zouzhe_log(new_id, caller, "CREATED",
                   f"奏折已创建：{title}",
                   priority=priority,
                   review_required=review_required,
                   timeout_sec=timeout_sec)

        # Discord notification for task creation
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        send_discord(
            new_id,
            f"🏛️ **奏折已创建**\n\n奏折：{new_id}\n标题：{title}\n优先级：{priority}\n"
            f"审核级别：{review_required}\n创建时间：{ts}\n\n等待中书省规划方案……",
            thread_id=discord_thread_id,
        )

        out({"ok": True, "id": new_id, "state": "created", "discord_thread_id": discord_thread_id})
    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_list(args):
    state_filter = None
    limit = 20

    i = 0
    while i < len(args):
        if args[i] == "--state" and i + 1 < len(args):
            state_filter = args[i + 1]
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            try:
                limit = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--limit must be an integer"}, ok=False)
            i += 2
        else:
            i += 1

    db = get_db()
    if state_filter:
        rows = db.execute(
            "SELECT id, title, state, assigned_agent, created_at FROM zouzhe "
            "WHERE state = ? ORDER BY created_at DESC LIMIT ?",
            (state_filter, limit),
        ).fetchall()
    else:
        rows = db.execute(
            "SELECT id, title, state, assigned_agent, created_at FROM zouzhe "
            "ORDER BY created_at DESC LIMIT ?",
            (limit,),
        ).fetchall()

    result = [dict(r) for r in rows]
    db.close()
    out({"ok": True, "zouzhe": result, "count": len(result)})


def cmd_status(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting status <zouzhe_id>"}, ok=False)

    zid = args[0]
    db = get_db()

    row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    zouzhe = dict(row)
    if zouzhe.get("plan"):
        try:
            zouzhe["plan"] = json.loads(zouzhe["plan"])
        except Exception:
            pass

    # Parse revise_history JSON for display
    if zouzhe.get("revise_history"):
        try:
            zouzhe["revise_history"] = json.loads(zouzhe["revise_history"])
        except Exception:
            pass

    toupiao = [
        {
            "id": r["id"],
            "round": r["round"],
            "jishi_id": r["jishi_id"],
            "agent_id": r["agent_id"],
            "vote": r["vote"],
            "reason": r["reason"],
            "timestamp": r["timestamp"],
        }
        for r in db.execute(
            "SELECT * FROM toupiao WHERE zouzhe_id = ? ORDER BY round, id",
            (zid,),
        ).fetchall()
    ]

    liuzhuan = [
        {
            "id": r["id"],
            "from_role": r["from_role"],
            "to_role": r["to_role"],
            "action": r["action"],
            "remark": r["remark"],
            "timestamp": r["timestamp"],
        }
        for r in db.execute(
            "SELECT * FROM liuzhuan WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    zoubao = [
        {
            "id": r["id"],
            "agent_id": r["agent_id"],
            "text": r["text"],
            "timestamp": r["timestamp"],
        }
        for r in db.execute(
            "SELECT * FROM zoubao WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    db.close()

    # Read step progress from plan file
    steps_done = None
    steps_total = None
    progress_pct = None
    plan_path = os.path.join(CHAOTING_DATA_DIR, "docs", "plans", f"{zid}.md")
    if os.path.isfile(plan_path):
        try:
            with open(plan_path, "r") as f:
                content = f.read()
            done_count = content.count("- [x] ")
            remaining_count = content.count("- [ ] ")
            total = done_count + remaining_count
            if total > 0:
                steps_done = done_count
                steps_total = total
                progress_pct = round(done_count / total * 100)
        except Exception as e:
            print(f"[WARN] failed to read plan file for step progress: {e}", file=sys.stderr)

    out({
        "ok": True,
        "zouzhe": zouzhe,
        "toupiao": toupiao,
        "liuzhuan": liuzhuan,
        "zoubao": zoubao,
        "steps_done": steps_done,
        "steps_total": steps_total,
        "progress_pct": progress_pct,
    })


def _detect_duplicate_reason(reason: str, revise_history: list, threshold: float = 0.85) -> dict:
    """
    使用 difflib.SequenceMatcher 检测当前返工原因是否与最近一轮高度相似。

    Args:
        reason: 当前返工原因文本
        revise_history: 现有 revise_history 数组
        threshold: 相似度阈值，默认 0.85

    Returns:
        {"duplicate": bool, "similarity": float, "similar_to_round": int|None}
    """
    if not revise_history:
        return {"duplicate": False, "similarity": 0.0, "similar_to_round": None}

    import difflib
    # 只检查最近 2 轮，防止与早期原因误判
    recent = revise_history[-2:] if len(revise_history) >= 2 else revise_history
    max_sim = 0.0
    similar_round = None

    for entry in recent:
        prev_reason = entry.get("reason", "")
        if not prev_reason:
            continue
        sim = difflib.SequenceMatcher(None, reason.strip(), prev_reason.strip()).ratio()
        if sim > max_sim:
            max_sim = sim
            similar_round = entry.get("round")

    return {
        "duplicate": max_sim >= threshold,
        "similarity": round(max_sim, 3),
        "similar_to_round": similar_round,
    }


def _check_revise_timeout(row) -> dict:
    """
    检查奏折是否超出防爆轮时间限制。

    Returns:
        {"expired": bool, "days_elapsed": float, "limit_days": int}
    """
    timeout_days = row["revise_timeout_days"] if row["revise_timeout_days"] else 0
    if timeout_days <= 0:
        return {"expired": False, "days_elapsed": 0.0, "limit_days": 0}

    created_at = row["created_at"]
    if not created_at:
        return {"expired": False, "days_elapsed": 0.0, "limit_days": timeout_days}

    try:
        from datetime import datetime, timezone
        created = datetime.fromisoformat(created_at.replace("Z", "+00:00"))
        if created.tzinfo is None:
            created = created.replace(tzinfo=timezone.utc)
        elapsed = (datetime.now(timezone.utc) - created).total_seconds() / 86400.0
        return {
            "expired": elapsed >= timeout_days,
            "days_elapsed": round(elapsed, 2),
            "limit_days": timeout_days,
        }
    except Exception:
        return {"expired": False, "days_elapsed": 0.0, "limit_days": timeout_days}


def cmd_revise(args):
    """Rollback a done zouzhe to revising state for full re-planning and re-review.

    Usage: chaoting revise <zouzhe_id> '<reason>' [--review N] [--limit N] [--timeout-days N]

    State transition: done → revising (dispatcher routes revising→planning→zhongshu)

    --review N        Set review_required level (0-3). Default: 2.
    --limit N         Set revise_limit. 0=无限制（默认）, N=最多N次.
    --timeout-days N  Set revise_timeout_days. 0=不限时, N=N天无突破触发suspended.

    In one atomic transaction:
    1. Check revise_limit (0=unlimited, skip cap check)
    2. Archive current toupiao votes into revise_history[].votes, then DELETE them
    3. Archive output/summary into revise_history[]
    4. Detect duplicate reason (difflib, threshold=0.85) — warn but do NOT block
    5. Check revise_timeout — if expired AND timeout_days>0, set suspended instead
    6. Reset revise_count=0, plan=NULL (fresh planning round)
    7. Update last_revise_reason, increment total_revise_rounds

    Only silijian and zhongshu may initiate (OPENCLAW_AGENT_ID).
    revise_limit=0 means unlimited (皇上下旨无上限).
    """
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting revise <zouzhe_id> '<reason>' [--review N] [--limit N] [--timeout-days N]"}, ok=False)

    zid = args[0]
    reason = args[1]

    # Parse flags
    new_review_required = 2
    new_revise_limit = None       # None = 不改变
    new_timeout_days = None       # None = 不改变
    i = 2
    while i < len(args):
        if args[i] == "--review" and i + 1 < len(args):
            try:
                new_review_required = int(args[i + 1])
                if new_review_required not in (0, 1, 2, 3):
                    out({"ok": False, "error": "--review must be 0, 1, 2, or 3"}, ok=False)
            except ValueError:
                out({"ok": False, "error": "--review must be an integer (0-3)"}, ok=False)
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            try:
                val = args[i + 1]
                new_revise_limit = 0 if val in ("none", "0", "unlimited") else int(val)
                if new_revise_limit < 0:
                    out({"ok": False, "error": "--limit must be >= 0 (0=unlimited)"}, ok=False)
            except ValueError:
                out({"ok": False, "error": "--limit must be a non-negative integer or 'none'"}, ok=False)
            i += 2
        elif args[i] == "--timeout-days" and i + 1 < len(args):
            try:
                new_timeout_days = int(args[i + 1])
                if new_timeout_days < 0:
                    out({"ok": False, "error": "--timeout-days must be >= 0 (0=disabled)"}, ok=False)
            except ValueError:
                out({"ok": False, "error": "--timeout-days must be a non-negative integer"}, ok=False)
            i += 2
        else:
            i += 1

    # Permission check: only silijian and zhongshu may revise
    caller = os.environ.get("OPENCLAW_AGENT_ID", "")
    allowed_callers = {"silijian", "zhongshu"}
    if caller not in allowed_callers:
        out({
            "ok": False,
            "error": f"权限不足：只有 silijian 或 zhongshu 可发起返工（当前身份: '{caller}'）",
        }, ok=False)

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
        if not row:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)
        # sqlite3.Row 不支持 .get()，转为 dict 以便访问 V0.4 新增字段
        row = dict(row)

        if row["state"] != "done":
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": f"只有 done 状态的奏折可返工，当前状态: '{row['state']}'"}, ok=False)

        # Check suspended state
        if row.get("suspended_at"):
            db.execute("ROLLBACK")
            db.close()
            out({
                "ok": False,
                "error": f"奏折已被暂停（防爆轮机制触发），请先使用 chaoting resume {zid} 解除暂停",
                "suspended_at": row["suspended_at"],
            }, ok=False)

        # ── V0.4：revise_limit 检查 (0=无限制) ──
        current_count = row["exec_revise_count"] or 0
        effective_limit = new_revise_limit if new_revise_limit is not None else (row.get("revise_limit") or 0)

        if effective_limit > 0 and current_count >= effective_limit:
            db.execute("ROLLBACK")
            db.close()
            out({
                "ok": False,
                "error": f"已达返工上限（{effective_limit}次），请调整 --limit 或新建奏折",
                "exec_revise_count": current_count,
                "revise_limit": effective_limit,
            }, ok=False)

        # ── 旧版固定上限（向后兼容：仅当 revise_limit=0 且调用时未传 --limit 时保持旧行为）──
        # 注意：皇上下旨 revise_limit=0（默认）即取消上限，此逻辑已跳过
        # 此处保留注释说明设计意图，不再执行固定上限检查

        # ── V0.4：防爆轮超时检查 ──
        effective_timeout = new_timeout_days if new_timeout_days is not None else (row.get("revise_timeout_days") or 0)
        timeout_info = _check_revise_timeout(dict(row) | {"revise_timeout_days": effective_timeout})
        will_suspend = timeout_info["expired"]

        # Archive current toupiao votes
        vote_rows = db.execute(
            "SELECT round, jishi_id, agent_id, vote, reason, timestamp "
            "FROM toupiao WHERE zouzhe_id = ? ORDER BY round, id",
            (zid,),
        ).fetchall()
        archived_votes = [
            {
                "round": v["round"], "jishi_id": v["jishi_id"], "agent_id": v["agent_id"],
                "vote": v["vote"], "reason": v["reason"], "timestamp": v["timestamp"],
            }
            for v in vote_rows
        ]

        # Build revise_history archive entry
        existing_history = []
        if row["revise_history"]:
            try:
                existing_history = json.loads(row["revise_history"])
            except Exception:
                existing_history = []

        # ── V0.4：重复原因检测 ──
        dup_check = _detect_duplicate_reason(reason, existing_history)
        dup_warning = None
        if dup_check["duplicate"]:
            dup_warning = (
                f"⚠️ 当前返工原因与第 {dup_check['similar_to_round']} 轮高度相似"
                f"（相似度 {dup_check['similarity']:.0%}）。"
                f"建议：在新一轮规划中提供更具体的改进方向。"
            )

        archive_entry = {
            "round": current_count + 1,
            # output 截断 500 字符防止 JSON 过大
            "output": (row["output"] or "")[:500] if row["output"] else None,
            "summary": row["summary"],
            "plan": json.loads(row["plan"]) if row["plan"] else None,
            "votes": archived_votes,
            "reason": reason,
            "revised_by": caller,
            "revised_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
            "prev_review_required": row["review_required"],
            "new_review_required": new_review_required,
            "dup_similarity": dup_check["similarity"],
        }
        existing_history.append(archive_entry)
        new_history_json = json.dumps(existing_history, ensure_ascii=False)

        db.execute("DELETE FROM toupiao WHERE zouzhe_id = ?", (zid,))

        # 计算新 total_revise_rounds
        new_total_rounds = (row.get("total_revise_rounds") or 0) + 1

        # 构建更新 SQL
        set_clauses = [
            "exec_revise_count = exec_revise_count + 1",
            "revise_count = 0",
            "plan = NULL",
            # ── 修复 ZZ-20260310-029：清空 plan_history 确保路径判断不被旧 nogo 污染 ──
            # format_revising_message 通过 plan_history[-1].votes 判断触发原因
            # （nogo → gate_reject 路径A；空 → emperor_revise 路径B）
            # 若不清空，上一轮执行前的 gate_reject 数据会导致 emperor_revise 后走错路径
            "plan_history = NULL",
            "review_required = ?",
            "review_agents = NULL",
            "revise_history = ?",
            "last_revise_reason = ?",
            "total_revise_rounds = ?",
            # ── V0.4 planning_version 锁定：每次 revise 时 +1 ──
            # 中书省提交新 plan 时必须携带最新 version，dispatcher 校验匹配才接受
            "planning_version = planning_version + 1",
            "output = NULL",
            "summary = NULL",
            "error = NULL",
            "dispatched_at = NULL",
            "updated_at = strftime('%Y-%m-%dT%H:%M:%S','now')",
        ]
        params = [new_review_required, new_history_json, reason[:500], new_total_rounds]

        # 可选：更新 revise_limit / revise_timeout_days
        if new_revise_limit is not None:
            set_clauses.append("revise_limit = ?")
            params.append(new_revise_limit)
        if new_timeout_days is not None:
            set_clauses.append("revise_timeout_days = ?")
            params.append(new_timeout_days)

        if will_suspend:
            # 防爆轮触发：进入 suspended 而非 revising
            set_clauses.append("state = 'suspended'")
            set_clauses.append("suspended_at = strftime('%Y-%m-%dT%H:%M:%S','now')")
            next_state = "suspended"
        else:
            set_clauses.append("state = 'revising'")
            next_state = "revising"

        params.append(zid)

        cursor = db.execute(
            f"UPDATE zouzhe SET {', '.join(set_clauses)} "
            "WHERE id = ? AND state = 'done' "
            "RETURNING id, exec_revise_count, revise_limit, total_revise_rounds, planning_version",
            params,
        )
        result = cursor.fetchone()
        if not result:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "状态冲突：奏折不再是 done 状态（CAS 失败）"}, ok=False)

        new_count = result["exec_revise_count"]

        remark_parts = [f"退回修改（第 {new_count} 次）", f"原因: {reason[:100]}"]
        if will_suspend:
            remark_parts.append(f"⚠️ 防爆轮：超过 {effective_timeout} 天，进入 suspended 状态")
        if dup_warning:
            remark_parts.append(f"⚠️ 重复原因（{dup_check['similarity']:.0%} 相似）")

        # ── 审计区分：emperor_revise（皇上下旨）vs gate_reject（门下省封驳）──
        # liuzhuan action 明确标记来源，便于审计追溯
        liuzhuan_action = "emperor_revise"
        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, ?, 'zhongshu', ?, ?)",
            (zid, caller, liuzhuan_action, "；".join(remark_parts)),
        )

        db.execute("COMMIT")
        db.close()

        # 皇上旨意明确回显：第 N 次旨意
        zouzhe_log(zid, caller, "EMPEROR_REVISE",
                   f"⚠️ 皇上下旨返工（第 {new_count} 次），不受门下省封驳次数限制",
                   actor=caller,
                   reason=reason,
                   emperor_revise_count=new_count,
                   total_revise_rounds=new_total_rounds,
                   suspended=will_suspend)

        send_discord(
            zid,
            _fmt_revise_thread(zid, caller, reason, new_count, next_state),
            thread_id=row["discord_thread_id"],
        )

        response = {
            "ok": True,
            "zouzhe_id": zid,
            "state": next_state,
            "exec_revise_count": new_count,
            "total_revise_rounds": new_total_rounds,
            "votes_cleared": len(archived_votes),
            "review_required": new_review_required,
            "revise_limit": result["revise_limit"],
            "planning_version": result["planning_version"],
            "reason": reason,
            "revised_by": caller,
            # ── 皇上下旨明确回显（ZZ-20260310-014 v2）──
            # 区分 emperor_revise（无限制）vs gate_reject（门下省封驳，有上限）
            "revise_type": "emperor_revise",
            "revise_message": f"皇上下旨返工，不受门下省封驳次数限制，当前是第 {new_count} 次旨意",
        }
        if dup_warning:
            response["warning"] = dup_warning
            response["dup_similarity"] = dup_check["similarity"]
        if will_suspend:
            response["suspended"] = True
            response["timeout_days"] = effective_timeout
            response["days_elapsed"] = timeout_info["days_elapsed"]

        out(response)

    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_resume(args):
    """解除奏折的暂停状态（防爆轮触发后使用）。

    Usage: chaoting resume <zouzhe_id> ['<reason>']

    State transition: suspended → done (重新允许 revise)
    Only silijian may resume (OPENCLAW_AGENT_ID).
    """
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting resume <zouzhe_id> ['<reason>']"}, ok=False)

    zid = args[0]
    reason = args[1] if len(args) > 1 else "人工解除暂停"

    caller = os.environ.get("OPENCLAW_AGENT_ID", "")
    if caller != "silijian":
        out({
            "ok": False,
            "error": f"权限不足：只有 silijian 可解除暂停（当前身份: '{caller}'）",
        }, ok=False)

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")
        row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
        if not row:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)
        row = dict(row)

        if row["state"] != "suspended":
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": f"奏折不在 suspended 状态，当前: '{row['state']}'"}, ok=False)

        cursor = db.execute(
            "UPDATE zouzhe SET state = 'done', suspended_at = NULL, "
            "updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'suspended' RETURNING id",
            (zid,),
        )
        if not cursor.fetchone():
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "CAS 失败，请重试"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, ?, 'dispatcher', 'resume', ?)",
            (zid, caller, f"解除暂停：{reason}"),
        )

        db.execute("COMMIT")
        db.close()

        zouzhe_log(zid, caller, "STATE_TRANSITION",
                   "suspended → done（暂停解除）",
                   actor=caller, reason=reason)

        out({"ok": True, "zouzhe_id": zid, "state": "done",
             "resumed_by": caller, "reason": reason})

    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_pull(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting pull <zouzhe_id>"}, ok=False)

    zid = args[0]
    db = get_db()

    row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    zouzhe = {
        "id": row["id"],
        "title": row["title"],
        "description": row["description"],
        "state": row["state"],
        "priority": row["priority"],
        "plan": json.loads(row["plan"]) if row["plan"] else None,
        # ── V0.4：返工上下文（修复 ZZ-20260310-013 RC-2：中书省无法获取返工原因）──
        "exec_revise_count": row["exec_revise_count"] or 0,
        "revise_history": json.loads(row["revise_history"]) if row["revise_history"] else [],
        "revise_limit": (row["revise_limit"] or 0),
        "total_revise_rounds": (row["total_revise_rounds"] or 0),
        "last_revise_reason": row["last_revise_reason"],
        "suspended_at": row["suspended_at"],
        # ── V0.4 planning_version（ZZ-20260310-015）──
        # 中书省必须在 plan JSON 中携带此版本号，cmd_plan 校验匹配才接受
        "planning_version": (row["planning_version"] or 1),
    }

    dianji = [
        {"key": r["context_key"], "value": r["context_value"], "confidence": r["confidence"]}
        for r in db.execute(
            "SELECT context_key, context_value, confidence FROM dianji "
            "WHERE agent_role = ?", (row["assigned_agent"],)
        ).fetchall()
    ]

    qianche = [
        r["lesson"]
        for r in db.execute(
            "SELECT lesson FROM qianche WHERE agent_role = ? OR zouzhe_id = ?",
            (row["assigned_agent"], zid),
        ).fetchall()
    ]

    liuzhuan = [
        {"from": r["from_role"], "to": r["to_role"], "action": r["action"], "remark": r["remark"]}
        for r in db.execute(
            "SELECT from_role, to_role, action, remark FROM liuzhuan WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    # Plan file and worktree path hints
    plan_file_path = os.path.join(CHAOTING_DATA_DIR, "docs", "plans", f"{zid}.md")
    plan_file = plan_file_path if os.path.isfile(plan_file_path) else None
    worktree_path = None
    if zouzhe["plan"] and isinstance(zouzhe["plan"], dict) and zouzhe["plan"].get("repo_path"):
        worktree_path = os.path.join(os.path.dirname(zouzhe["plan"]["repo_path"]), f"worktree-{zid}")

    db.close()
    out({"ok": True, "zouzhe": zouzhe, "dianji": dianji, "qianche": qianche, "liuzhuan": liuzhuan,
         "plan_file": plan_file, "worktree_path": worktree_path})


def _write_plan_md(zid, plan, target_agent):
    """Write plan data to a Markdown file at CHAOTING_DATA_DIR/docs/plans/{zid}.md."""
    try:
        plan_dir = os.path.join(CHAOTING_DATA_DIR, "docs", "plans")
        os.makedirs(plan_dir, exist_ok=True)
        plan_path = os.path.join(plan_dir, f"{zid}.md")
        now = datetime.now(timezone.utc).isoformat()
        title = plan.get("title", plan.get("description", "untitled"))
        description = plan.get("description", "N/A")
        steps = plan.get("steps", [])
        acceptance_criteria = plan.get("acceptance_criteria", "N/A")
        steps_text = "\n".join(f"- [ ] {i+1}. {s}" for i, s in enumerate(steps)) if steps else "N/A"
        content = (
            f"# Plan: {zid} — {title}\n"
            f"\n"
            f"**Status**: planning  \n"
            f"**Target Agent**: {target_agent}  \n"
            f"**Created**: {now}\n"
            f"\n"
            f"## Task Description\n"
            f"\n"
            f"{description}\n"
            f"\n"
            f"## Steps\n"
            f"\n"
            f"{steps_text}\n"
            f"\n"
            f"## Acceptance Criteria\n"
            f"\n"
            f"{acceptance_criteria}\n"
        )
        with open(plan_path, "w") as f:
            f.write(content)
    except Exception as e:
        print(f"[WARN] failed to write plan file for {zid}: {e}", file=sys.stderr)


def cmd_plan(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting plan <zouzhe_id> '<plan_json>'"}, ok=False)

    zid = args[0]
    plan_raw = args[1]

    try:
        plan = json.loads(plan_raw)
    except json.JSONDecodeError as e:
        out({"ok": False, "error": f"invalid plan JSON: {e}"}, ok=False)

    target_agent = plan.get("target_agent")
    if not target_agent:
        out({"ok": False, "error": "plan must include target_agent"}, ok=False)

    db = get_db()

    # Check if review is required
    zouzhe = db.execute(
        "SELECT id, review_required, discord_thread_id, planning_version FROM zouzhe "
        "WHERE id = ? AND state = 'planning'",
        (zid,),
    ).fetchone()
    if not zouzhe:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in planning state"}, ok=False)

    # ── V0.4 planning_version 锁定校验（ZZ-20260310-015）──
    # 中书省提交 plan 时应在 plan JSON 中携带 planning_version 字段
    # 若存在则校验匹配，不匹配说明是过时的旧规划，拒绝接受
    plan_version_in_plan = plan.get("planning_version")
    db_version = zouzhe["planning_version"] or 1
    if plan_version_in_plan is not None and int(plan_version_in_plan) != db_version:
        db.close()
        out({
            "ok": False,
            "error": (
                f"planning_version 不匹配：规划版本 {plan_version_in_plan} 已过时，"
                f"当前 DB 版本为 {db_version}。"
                f"请先 chaoting pull {zid} 获取最新版本后重新规划。"
            ),
            "plan_version_submitted": plan_version_in_plan,
            "plan_version_required": db_version,
            "zouzhe_id": zid,
        }, ok=False)

    thread_id = zouzhe["discord_thread_id"]

    if zouzhe["review_required"]:
        # Enter reviewing state — dispatcher will dispatch to 给事中
        cursor = db.execute(
            "UPDATE zouzhe SET state = 'reviewing', plan = ?, assigned_agent = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'planning' RETURNING id",
            (plan_raw, target_agent, zid),
        )
        row = cursor.fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": "state conflict — CAS failed"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, 'zhongshu', 'menxia', 'submit_review', ?)",
            (zid, "planning complete, entering review"),
        )
        db.commit()
        db.close()
        _write_plan_md(zid, plan, target_agent)
        zouzhe_log(zid, "zhongshu", "PLAN_SUBMIT",
                   "计划已提交门下省审核",
                   target_agent=target_agent,
                   next_state="reviewing")
        send_discord(zid, _fmt_plan_thread(zid, target_agent, "reviewing", plan_raw), thread_id=thread_id)
        plan_file = os.path.join(CHAOTING_DATA_DIR, "docs", "plans", f"{zid}.md")
        out({"ok": True, "zouzhe_id": zid, "state": "reviewing", "target_agent": target_agent,
             "plan_file": plan_file if os.path.isfile(plan_file) else None})
    else:
        # Skip review — go directly to executing
        cursor = db.execute(
            "UPDATE zouzhe SET state = 'executing', plan = ?, assigned_agent = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'planning' RETURNING id",
            (plan_raw, target_agent, zid),
        )
        row = cursor.fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": "state conflict — CAS failed"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, 'zhongshu', ?, 'complete', ?)",
            (zid, target_agent, "planning complete, dispatching to agent"),
        )
        db.commit()
        db.close()
        _write_plan_md(zid, plan, target_agent)
        zouzhe_log(zid, "zhongshu", "PLAN_SUBMIT",
                   "计划已提交，直接进入执行（免审）",
                   target_agent=target_agent,
                   next_state="executing")
        send_discord(zid, _fmt_plan_thread(zid, target_agent, "executing", plan_raw), thread_id=thread_id)
        plan_file = os.path.join(CHAOTING_DATA_DIR, "docs", "plans", f"{zid}.md")
        out({"ok": True, "zouzhe_id": zid, "state": "executing", "target_agent": target_agent,
             "plan_file": plan_file if os.path.isfile(plan_file) else None})


def cmd_progress(args):
    import argparse
    parser = argparse.ArgumentParser(prog="chaoting progress", add_help=False)
    parser.add_argument("zid")
    parser.add_argument("text")
    parser.add_argument("--step", type=int, default=None)
    try:
        parsed = parser.parse_args(args)
    except SystemExit:
        out({"ok": False, "error": "usage: chaoting progress <zouzhe_id> '<text>' [--step N]"}, ok=False)
        return

    zid = parsed.zid
    text = parsed.text
    step = parsed.step

    db = get_db()
    row = db.execute("SELECT id FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    # Update step checkbox in plan file if --step N provided
    if step is not None:
        plan_path = os.path.join(CHAOTING_DATA_DIR, "docs", "plans", f"{zid}.md")
        if os.path.isfile(plan_path):
            try:
                with open(plan_path, "r") as f:
                    lines = f.readlines()
                updated = False
                for i, line in enumerate(lines):
                    if line.strip().startswith(f"- [ ] {step}."):
                        lines[i] = line.replace("- [ ] ", "- [x] ", 1)
                        updated = True
                        break
                if updated:
                    with open(plan_path, "w") as f:
                        f.writelines(lines)
                else:
                    print(f"[WARN] step {step} not found in plan file {plan_path}", file=sys.stderr)
            except Exception as e:
                print(f"[WARN] failed to update plan file step: {e}", file=sys.stderr)
        else:
            print(f"[WARN] plan file not found: {plan_path}", file=sys.stderr)

    db.execute(
        "INSERT INTO zoubao (zouzhe_id, agent_id, text) VALUES (?, ?, ?)",
        (zid, None, text),
    )
    db.execute(
        "UPDATE zouzhe SET updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') WHERE id = ?",
        (zid,),
    )
    db.commit()
    db.close()
    out({"ok": True, "zouzhe_id": zid, "action": "progress"})


def _parse_done_extras(args):
    """Parse --dianji key=value and --lesson text flags from args[3:].

    Returns (dianji_entries, lesson_entries) where:
      dianji_entries = [{"key": ..., "value": ...}, ...]
      lesson_entries = ["lesson text", ...]
    """
    dianji_entries = []
    lesson_entries = []
    i = 0
    while i < len(args):
        if args[i] == "--dianji" and i + 1 < len(args):
            kv = args[i + 1]
            if "=" in kv:
                k, _, v = kv.partition("=")
                dianji_entries.append({"key": k.strip(), "value": v.strip()})
            else:
                print(f"[WARN] --dianji '{kv}' 缺少 '='，格式应为 key=value，已跳过", file=sys.stderr)
            i += 2
        elif args[i] == "--lesson" and i + 1 < len(args):
            lesson_entries.append(args[i + 1])
            i += 2
        else:
            i += 1
    return dianji_entries, lesson_entries


def cmd_done(args):
    if len(args) < 3:
        out({
            "ok": False,
            "error": (
                "usage: chaoting done <zouzhe_id> '<output>' '<summary>'"
                " [--dianji key=value ...] [--lesson '<text>' ...]"
            ),
        }, ok=False)

    zid = args[0]
    output = args[1]
    summary = args[2]
    dianji_entries, lesson_entries = _parse_done_extras(args[3:])

    db = get_db()
    cursor = db.execute(
        "UPDATE zouzhe SET state = 'done', output = ?, summary = ?, "
        "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
        "WHERE id = ? AND state = 'executing' RETURNING id",
        (output, summary, zid),
    )
    row = cursor.fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in executing state"}, ok=False)

    zz = db.execute("SELECT assigned_agent, discord_thread_id FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    assigned_agent = zz["assigned_agent"] if zz else None
    thread_id = zz["discord_thread_id"] if zz else None

    db.execute(
        "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
        "VALUES (?, ?, 'dispatcher', 'complete', ?)",
        (zid, assigned_agent, summary),
    )
    db.commit()

    # ── P0: Write dianji entries (典籍) if provided ──
    for entry in dianji_entries:
        try:
            db.execute(
                "INSERT INTO dianji (agent_role, context_key, context_value, source, updated_at) "
                "VALUES (?, ?, ?, ?, strftime('%Y-%m-%dT%H:%M:%S','now')) "
                "ON CONFLICT(agent_role, context_key) DO UPDATE SET "
                "context_value = excluded.context_value, source = excluded.source, "
                "confidence = 'fresh', updated_at = strftime('%Y-%m-%dT%H:%M:%S','now')",
                (assigned_agent or "unknown", entry["key"], entry["value"], zid),
            )
        except Exception as e:
            print(f"[WARN] dianji write failed for '{entry['key']}': {e}", file=sys.stderr)
    # ── P0: Write lesson entries (牵扯) if provided ──
    for lesson in lesson_entries:
        try:
            db.execute(
                "INSERT INTO qianche (agent_role, zouzhe_id, lesson) VALUES (?, ?, ?)",
                (assigned_agent or "unknown", zid, lesson),
            )
        except Exception as e:
            print(f"[WARN] qianche write failed: {e}", file=sys.stderr)
    if dianji_entries or lesson_entries:
        db.commit()

    db.close()

    # Append completion section to plan file if it exists
    _append_plan_completion(zid, output, summary)

    # Audit log: record completion in agent's log file
    zouzhe_log(zid, assigned_agent or "unknown", "COMPLETED",
               "✅ 任务完成",
               output=(output or "")[:500],
               summary=summary)

    # Discord notification for completion
    send_discord(zid, _fmt_done_thread(zid, assigned_agent or "unknown", output, summary), thread_id=thread_id)

    worktree_path = os.path.join(os.path.expanduser("~/self-project"), f"worktree-{zid}")
    out({"ok": True, "zouzhe_id": zid, "state": "done",
         "worktree_cleanup_hint": f"git worktree remove {worktree_path} && git branch -D pr/{zid}-*"})


def _append_plan_completion(zid, output, summary):
    """Append a completion section to the plan Markdown file if it exists."""
    try:
        plan_path = os.path.join(CHAOTING_DATA_DIR, "docs", "plans", f"{zid}.md")
        if not os.path.isfile(plan_path):
            return
        now = datetime.now(timezone.utc).isoformat()
        worktree_line = ""
        # Try to derive worktree path from plan file content is not worth it;
        # use the standard naming convention instead
        worktree_dir = os.path.join(os.path.dirname(os.path.dirname(os.path.dirname(CHAOTING_DATA_DIR))),
                                     f"worktree-{zid}")
        if os.path.isdir(worktree_dir):
            worktree_line = f"**Worktree cleanup**: `git worktree remove {worktree_dir}` (if applicable)\n"
        section = (
            f"\n---\n"
            f"\n"
            f"## Completion\n"
            f"\n"
            f"**Output**: {output}  \n"
            f"**Summary**: {summary}  \n"
            f"**Completed at**: {now}  \n"
            f"{worktree_line}"
        )
        with open(plan_path, "a") as f:
            f.write(section)
    except Exception as e:
        print(f"[WARN] failed to append completion to plan file for {zid}: {e}", file=sys.stderr)


