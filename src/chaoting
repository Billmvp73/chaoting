def cmd_push_for_review(args):
    """Submit executor's work for yushi PR code review.

    Usage: chaoting push-for-review <zouzhe_id> '<output_with_pr_url>'
               [--service <name>] [--skip-health-check]

    State transition: executing → pr_review

    - Saves output description (must include PR URL) to output field
    - Clears dispatched_at so dispatcher re-dispatches to yushi
    - Records liuzhuan: executor → dispatcher | push_for_review
    - Must be called before chaoting done (yushi-approve triggers done)
    - Layer 2: auto-commits docs/test-results/<ZZ-ID>.md if present in repo
    - Layer 3: enforces health gate if --service is given (bypass: --skip-health-check)
    """
    if len(args) < 2:
        out({
            "ok": False,
            "error": "usage: chaoting push-for-review <zouzhe_id> '<output_with_pr_url>' [--service <name>] [--skip-health-check]",
        }, ok=False)

    zid = args[0]
    output = args[1]

    # Parse optional flags
    service_name = None
    skip_health_check = False
    i = 2
    while i < len(args):
        if args[i] == "--service" and i + 1 < len(args):
            service_name = args[i + 1]
            i += 2
        elif args[i] == "--skip-health-check":
            skip_health_check = True
            i += 1
        else:
            i += 1

    db = get_db()
    try:
        row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

        row = dict(row)
        if row["state"] != "executing":
            db.close()
            out({
                "ok": False,
                "error": f"push-for-review 只能在 executing 状态调用，当前状态: '{row['state']}'",
            }, ok=False)

        assigned_agent = row.get("assigned_agent")
        thread_id = row.get("discord_thread_id")

        # Extract repo_path from plan JSON for Layer 2 & Layer 3
        repo_path = None
        try:
            if row.get("plan"):
                plan_obj = json.loads(row["plan"])
                repo_path = plan_obj.get("repo_path")
        except (json.JSONDecodeError, TypeError):
            pass

        # ── Layer 3: Health Gate ──────────────────────────────────────────────
        health_note = None
        if service_name and not skip_health_check:
            try:
                health = _check_service_health(service_name)
                if not health["healthy"]:
                    db.close()
                    out({
                        "ok": False,
                        "error": (
                            f"Health gate FAILED for service '{service_name}': "
                            f"{'; '.join(health['details'])}. "
                            f"Use --skip-health-check to bypass."
                        ),
                    }, ok=False)
                health_note = f"health gate passed: {service_name} is active"
            except Exception as he:
                db.close()
                out({"ok": False, "error": f"Health gate error: {he}"}, ok=False)
        elif service_name and skip_health_check:
            health_note = f"health gate skipped (--skip-health-check) for service '{service_name}'"
        # If no service_name given: health gate not applicable, proceed silently

        # ── Layer 2: Test Results Persistence ────────────────────────────────
        test_results_committed = False
        test_results_note = None
        if repo_path:
            test_results_file = os.path.join(repo_path, "docs", "test-results", f"{zid}.md")
            if os.path.isfile(test_results_file):
                try:
                    # Stage and commit test results into the current branch
                    rel_path = os.path.join("docs", "test-results", f"{zid}.md")
                    add_result = subprocess.run(
                        ["git", "add", rel_path],
                        cwd=repo_path, capture_output=True, text=True, timeout=15,
                    )
                    if add_result.returncode != 0:
                        test_results_note = f"git add failed: {add_result.stderr.strip()}"
                    else:
                        commit_result = subprocess.run(
                            ["git", "commit", "-m", f"test: add test results for {zid}"],
                            cwd=repo_path, capture_output=True, text=True, timeout=15,
                        )
                        if commit_result.returncode == 0:
                            test_results_committed = True
                            test_results_note = f"test results committed: {rel_path}"
                        elif "nothing to commit" in commit_result.stdout.lower():
                            test_results_note = "test results file already committed"
                        else:
                            test_results_note = f"git commit failed: {commit_result.stderr.strip()}"
                except Exception as te:
                    test_results_note = f"test results commit error: {te}"
            else:
                test_results_note = f"no test results file at {test_results_file} — skipped"

        cursor = db.execute(
            "UPDATE zouzhe SET state = 'pr_review', output = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'executing' RETURNING id",
            (output, zid),
        )
        if not cursor.fetchone():
            db.close()
            out({"ok": False, "error": "状态冲突：CAS 失败，奏折不再是 executing 状态"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, ?, 'dispatcher', 'push_for_review', ?)",
            (zid, assigned_agent or "executor", f"executing → pr_review，提交御史审核"),
        )
        db.commit()
        db.close()

        zouzhe_log(zid, assigned_agent or "executor", "PUSH_FOR_REVIEW",
                   "📤 代码已提交御史审核，executing → pr_review",
                   output=(output or "")[:500])

        send_discord(
            zid,
            _fmt_push_for_review_thread(zid, assigned_agent or "executor", output),
            thread_id=thread_id,
        )

        response = {
            "ok": True,
            "zouzhe_id": zid,
            "state": "pr_review",
            "note": "dispatcher 将在下次 poll 中派发御史（yushi）审核",
        }
        if health_note:
            response["health_note"] = health_note
        if test_results_note:
            response["test_results_note"] = test_results_note
        if test_results_committed:
            response["test_results_committed"] = True
        out(response)

    except Exception as e:
        try:
            db.close()
        except Exception:
            pass
        out({"ok": False, "error": str(e)}, ok=False)


