def cmd_revise(args):
    """Rollback a done zouzhe to revising state for full re-planning and re-review.

    Usage: chaoting revise <zouzhe_id> '<reason>' [--review N]

    State transition: done → revising (dispatcher routes revising→planning→zhongshu)

    --review N  Set review_required level for the new round (0-3).
                Default: 2 (jishi_tech + jishi_risk — 司礼监标准审核级别).

    In one atomic transaction:
    1. Archive current toupiao votes into revise_history[].votes, then DELETE them
    2. Archive output/summary into revise_history[]
    3. Reset revise_count=0, plan=NULL (fresh planning round)
    4. Set state=revising, increment exec_revise_count, clear output/summary

    Only silijian and zhongshu may initiate (OPENCLAW_AGENT_ID).
    exec_revise_count capped at 3 (normal/high) or 5 (critical).
    """
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting revise <zouzhe_id> '<reason>' [--review N]"}, ok=False)

    zid = args[0]
    reason = args[1]

    # Parse --review flag (default: 2 — 司礼监标准审核级别: jishi_tech + jishi_risk)
    new_review_required = 2
    i = 2
    while i < len(args):
        if args[i] == "--review" and i + 1 < len(args):
            try:
                new_review_required = int(args[i + 1])
                if new_review_required not in (0, 1, 2, 3):
                    out({"ok": False, "error": "--review must be 0, 1, 2, or 3"}, ok=False)
            except ValueError:
                out({"ok": False, "error": "--review must be an integer (0-3)"}, ok=False)
            i += 2
        else:
            i += 1

    # Permission check: only silijian and zhongshu may revise
    caller = os.environ.get("OPENCLAW_AGENT_ID", "")
    allowed_callers = {"silijian", "zhongshu"}
    if caller not in allowed_callers:
        out({
            "ok": False,
            "error": f"权限不足：只有 silijian 或 zhongshu 可发起返工（当前身份: '{caller}'）",
        }, ok=False)

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
        if not row:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

        if row["state"] != "done":
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": f"只有 done 状态的奏折可返工，当前状态: '{row['state']}'"}, ok=False)

        # Check revise count cap
        current_count = row["exec_revise_count"] or 0
        max_revises = 5 if row["priority"] == "critical" else 3
        if current_count >= max_revises:
            db.execute("ROLLBACK")
            db.close()
            out({
                "ok": False,
                "error": f"超过最大返工次数（{max_revises}次），请新建奏折",
                "exec_revise_count": current_count,
            }, ok=False)

        # Archive current toupiao votes (all rounds) before deleting
        vote_rows = db.execute(
            "SELECT round, jishi_id, agent_id, vote, reason, timestamp "
            "FROM toupiao WHERE zouzhe_id = ? ORDER BY round, id",
            (zid,),
        ).fetchall()
        archived_votes = [
            {
                "round": v["round"],
                "jishi_id": v["jishi_id"],
                "agent_id": v["agent_id"],
                "vote": v["vote"],
                "reason": v["reason"],
                "timestamp": v["timestamp"],
            }
            for v in vote_rows
        ]

        # Build revise_history archive entry (includes votes)
        existing_history = []
        if row["revise_history"]:
            try:
                existing_history = json.loads(row["revise_history"])
            except Exception:
                existing_history = []

        archive_entry = {
            "round": current_count + 1,
            "output": row["output"],
            "summary": row["summary"],
            "plan": json.loads(row["plan"]) if row["plan"] else None,
            "votes": archived_votes,
            "reason": reason,
            "revised_by": caller,
            "revised_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S"),
            "prev_review_required": row["review_required"],
            "new_review_required": new_review_required,
        }
        existing_history.append(archive_entry)
        new_history_json = json.dumps(existing_history, ensure_ascii=False)

        # Delete archived votes from toupiao (clean slate for new review round)
        db.execute("DELETE FROM toupiao WHERE zouzhe_id = ?", (zid,))

        # CAS update: only transition from done
        # Reset revise_count=0 and plan=NULL for fresh planning + review round
        # Also update review_required to the requested level (default 2)
        cursor = db.execute(
            "UPDATE zouzhe SET "
            "  state = 'revising', "
            "  exec_revise_count = exec_revise_count + 1, "
            "  revise_count = 0, "
            "  plan = NULL, "
            "  review_required = ?, "
            "  review_agents = NULL, "
            "  revise_history = ?, "
            "  output = NULL, "
            "  summary = NULL, "
            "  error = NULL, "
            "  dispatched_at = NULL, "
            "  updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'done' "
            "RETURNING id, exec_revise_count",
            (new_review_required, new_history_json, zid),
        )
        result = cursor.fetchone()
        if not result:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "状态冲突：奏折不再是 done 状态（CAS 失败）"}, ok=False)

        new_count = result["exec_revise_count"]

        # Audit trail in liuzhuan
        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, ?, 'zhongshu', 'revise', ?)",
            (zid, caller,
             f"退回修改（第 {new_count} 次），原因：{reason}；投票已清除，重新进入规划"),
        )

        db.execute("COMMIT")
        db.close()

        zouzhe_log(zid, caller, "STATE_TRANSITION",
                   "done → revising（重新规划+评审）",
                   actor=caller,
                   reason=reason,
                   revise_count=new_count,
                   votes_archived=len(archived_votes),
                   plan_cleared="YES",
                   review_required=new_review_required)

        # Discord notification for revise
        send_discord(
            zid,
            _fmt_revise_thread(zid, caller, reason, new_count, "revising"),
            thread_id=row["discord_thread_id"],
        )
        out({
            "ok": True,
            "zouzhe_id": zid,
            "state": "revising",
            "exec_revise_count": new_count,
            "votes_cleared": len(archived_votes),
            "review_required": new_review_required,
            "reason": reason,
            "revised_by": caller,
        })

    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_pull(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting pull <zouzhe_id>"}, ok=False)

    zid = args[0]
    db = get_db()

    row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    zouzhe = {
        "id": row["id"],
        "title": row["title"],
        "description": row["description"],
        "state": row["state"],
        "priority": row["priority"],
        "plan": json.loads(row["plan"]) if row["plan"] else None,
    }

    dianji = [
        {"key": r["context_key"], "value": r["context_value"], "confidence": r["confidence"]}
        for r in db.execute(
            "SELECT context_key, context_value, confidence FROM dianji "
            "WHERE agent_role = ?", (row["assigned_agent"],)
        ).fetchall()
    ]

    qianche = [
        r["lesson"]
        for r in db.execute(
            "SELECT lesson FROM qianche WHERE agent_role = ? OR zouzhe_id = ?",
            (row["assigned_agent"], zid),
        ).fetchall()
    ]

    liuzhuan = [
        {"from": r["from_role"], "to": r["to_role"], "action": r["action"], "remark": r["remark"]}
        for r in db.execute(
            "SELECT from_role, to_role, action, remark FROM liuzhuan WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    db.close()
    out({"ok": True, "zouzhe": zouzhe, "dianji": dianji, "qianche": qianche, "liuzhuan": liuzhuan})


def cmd_plan(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting plan <zouzhe_id> '<plan_json>'"}, ok=False)

    zid = args[0]
    plan_raw = args[1]

    try:
        plan = json.loads(plan_raw)
    except json.JSONDecodeError as e:
        out({"ok": False, "error": f"invalid plan JSON: {e}"}, ok=False)

    target_agent = plan.get("target_agent")
    if not target_agent:
        out({"ok": False, "error": "plan must include target_agent"}, ok=False)

    db = get_db()

    # Check if review is required
    zouzhe = db.execute(
        "SELECT id, review_required, discord_thread_id FROM zouzhe WHERE id = ? AND state = 'planning'",
        (zid,),
    ).fetchone()
    if not zouzhe:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in planning state"}, ok=False)

    thread_id = zouzhe["discord_thread_id"]

    if zouzhe["review_required"]:
        # Enter reviewing state — dispatcher will dispatch to 给事中
        cursor = db.execute(
            "UPDATE zouzhe SET state = 'reviewing', plan = ?, assigned_agent = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'planning' RETURNING id",
            (plan_raw, target_agent, zid),
        )
        row = cursor.fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": "state conflict — CAS failed"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, 'zhongshu', 'menxia', 'submit_review', ?)",
            (zid, "planning complete, entering review"),
        )
        db.commit()
        db.close()
        zouzhe_log(zid, "zhongshu", "PLAN_SUBMIT",
                   "计划已提交门下省审核",
                   target_agent=target_agent,
                   next_state="reviewing")
        send_discord(zid, _fmt_plan_thread(zid, target_agent, "reviewing"), thread_id=thread_id)
        out({"ok": True, "zouzhe_id": zid, "state": "reviewing", "target_agent": target_agent})
    else:
        # Skip review — go directly to executing
        cursor = db.execute(
            "UPDATE zouzhe SET state = 'executing', plan = ?, assigned_agent = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'planning' RETURNING id",
            (plan_raw, target_agent, zid),
        )
        row = cursor.fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": "state conflict — CAS failed"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, 'zhongshu', ?, 'complete', ?)",
            (zid, target_agent, "planning complete, dispatching to agent"),
        )
        db.commit()
        db.close()
        zouzhe_log(zid, "zhongshu", "PLAN_SUBMIT",
                   "计划已提交，直接进入执行（免审）",
                   target_agent=target_agent,
                   next_state="executing")
        send_discord(zid, _fmt_plan_thread(zid, target_agent, "executing"), thread_id=thread_id)
        out({"ok": True, "zouzhe_id": zid, "state": "executing", "target_agent": target_agent})


def cmd_progress(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting progress <zouzhe_id> '<text>'"}, ok=False)

    zid = args[0]
    text = args[1]

    db = get_db()
    row = db.execute("SELECT id FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    db.execute(
        "INSERT INTO zoubao (zouzhe_id, agent_id, text) VALUES (?, ?, ?)",
        (zid, None, text),
    )
    db.execute(
        "UPDATE zouzhe SET updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') WHERE id = ?",
        (zid,),
    )
    db.commit()
    db.close()
    out({"ok": True, "zouzhe_id": zid, "action": "progress"})


def cmd_done(args):
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting done <zouzhe_id> '<output>' '<summary>'"}, ok=False)

    zid = args[0]
    output = args[1]
    summary = args[2]

    db = get_db()
    cursor = db.execute(
        "UPDATE zouzhe SET state = 'done', output = ?, summary = ?, "
        "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
        "WHERE id = ? AND state = 'executing' RETURNING id",
        (output, summary, zid),
    )
    row = cursor.fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in executing state"}, ok=False)

    zz = db.execute("SELECT assigned_agent, discord_thread_id FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    assigned_agent = zz["assigned_agent"] if zz else None
    thread_id = zz["discord_thread_id"] if zz else None

    db.execute(
        "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
        "VALUES (?, ?, 'dispatcher', 'complete', ?)",
        (zid, assigned_agent, summary),
    )
    db.commit()
    db.close()

    # Audit log: record completion in agent's log file
    zouzhe_log(zid, assigned_agent or "unknown", "COMPLETED",
               "✅ 任务完成",
               output=(output or "")[:500],
               summary=summary)

    # Discord notification for completion
    send_discord(zid, _fmt_done_thread(zid, assigned_agent or "unknown", output, summary), thread_id=thread_id)

    out({"ok": True, "zouzhe_id": zid, "state": "done"})


def cmd_fail(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting fail <zouzhe_id> '<reason>'"}, ok=False)

    zid = args[0]
    reason = args[1]

    db = get_db()
    cursor = db.execute(
        "UPDATE zouzhe SET state = 'failed', error = ?, "
        "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
        "WHERE id = ? AND state IN ('planning', 'executing') RETURNING id",
        (reason, zid),
    )
    row = cursor.fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in active state"}, ok=False)

    zz = db.execute("SELECT assigned_agent, discord_thread_id FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    assigned_agent = zz["assigned_agent"] if zz else None
    thread_id = zz["discord_thread_id"] if zz else None

    db.execute(
        "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
        "VALUES (?, ?, 'dispatcher', 'fail', ?)",
        (zid, assigned_agent, reason),
    )
    db.commit()
    db.close()

    # Audit log: record failure in agent's log file
    zouzhe_log(zid, assigned_agent or "unknown", "FAILED",
               "❌ 任务失败",
               reason=reason)

    # Discord notification for failure
    send_discord(zid, _fmt_fail_thread(zid, assigned_agent or "unknown", reason), thread_id=thread_id)

    out({"ok": True, "zouzhe_id": zid, "state": "failed"})


def cmd_context(args):
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting context <agent_role> <key> <value> [--source ZZ-...]"}, ok=False)

    agent_role = args[0]
    key = args[1]
    value = args[2]
    source = None
    if "--source" in args:
        idx = args.index("--source")
        if idx + 1 < len(args):
            source = args[idx + 1]

    db = get_db()
    db.execute(
        "INSERT INTO dianji (agent_role, context_key, context_value, source, updated_at) "
        "VALUES (?, ?, ?, ?, strftime('%Y-%m-%dT%H:%M:%S','now')) "
        "ON CONFLICT(agent_role, context_key) DO UPDATE SET "
        "context_value = excluded.context_value, source = excluded.source, "
        "confidence = 'fresh', updated_at = strftime('%Y-%m-%dT%H:%M:%S','now')",
        (agent_role, key, value, source),
    )
    db.commit()
    db.close()
    out({"ok": True, "agent_role": agent_role, "context_key": key})


def cmd_vote(args):
    # Parse: chaoting vote ZZ-xxx go/nogo 'reason' --as jishi_tech
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting vote <zouzhe_id> <go|nogo> '<reason>' --as <jishi_id>"}, ok=False)

    zid = args[0]
    vote = args[1]
    reason = args[2] if len(args) > 2 else ""

    if vote not in ("go", "nogo"):
        out({"ok": False, "error": "vote must be 'go' or 'nogo'"}, ok=False)

    # Parse --as parameter
    jishi_id = None
    if "--as" in args:
        idx = args.index("--as")
        if idx + 1 < len(args):
            jishi_id = args[idx + 1]
    if not jishi_id:
        out({"ok": False, "error": "--as <jishi_id> is required"}, ok=False)

    agent_id = os.environ.get("OPENCLAW_AGENT_ID", "unknown")

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        zouzhe = db.execute(
            "SELECT id, revise_count, discord_thread_id FROM zouzhe WHERE id = ? AND state = 'reviewing'",
            (zid,),
        ).fetchone()

        if not zouzhe:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "zouzhe not in reviewing state"}, ok=False)

        current_round = (zouzhe["revise_count"] or 0) + 1

        cursor = db.execute(
            "INSERT OR IGNORE INTO toupiao (zouzhe_id, round, jishi_id, agent_id, vote, reason) "
            "VALUES (?, ?, ?, ?, ?, ?)",
            (zid, current_round, jishi_id, agent_id, vote, reason),
        )

        if cursor.rowcount == 0:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "already voted this round"}, ok=False)

        db.execute("COMMIT")
        thread_id = zouzhe["discord_thread_id"]
        db.close()
        zouzhe_log(zid, jishi_id, "VOTE",
                   vote.upper(),
                   jishi=jishi_id,
                   round=current_round,
                   reason=reason)
        send_discord(zid, _fmt_vote_thread(zid, jishi_id, vote, reason, current_round), thread_id=thread_id)
        out({"ok": True, "action": "vote", "zouzhe_id": zid, "vote": vote,
             "jishi_id": jishi_id, "round": current_round})
    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_notify(args):
    """Send a Discord notification for a zouzhe. Used by dispatcher for system events."""
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting notify <zouzhe_id> '<message>'"}, ok=False)

    zid = args[0]
    body = args[1]

    sent = send_discord(zid, body)
    out({"ok": sent, "zouzhe_id": zid, "action": "notify"}, ok=sent)


COMMANDS = {
    "new": cmd_new,
    "list": cmd_list,
    "status": cmd_status,
    "revise": cmd_revise,
    "pull": cmd_pull,
    "plan": cmd_plan,
    "progress": cmd_progress,
    "done": cmd_done,
    "fail": cmd_fail,
    "context": cmd_context,
    "vote": cmd_vote,
    "notify": cmd_notify,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        cmds = ", ".join(COMMANDS.keys())
        out({"ok": False, "error": f"usage: chaoting <{cmds}> [args...]"}, ok=False)

    cmd = sys.argv[1]
    COMMANDS[cmd](sys.argv[2:])


if __name__ == "__main__":
    main()
