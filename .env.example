# Chaoting configuration — copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. It is loaded by dispatcher.py, the chaoting CLI,
# and configure.sh (for systemd service generation).

# Path to CLI binary (auto-detected from PATH if not set)
OPENCLAW_CLI=
# State directory
OPENCLAW_STATE_DIR=
# Discord channel ID for fallback notifications (optional)
DISCORD_FALLBACK_CHANNEL_ID=
