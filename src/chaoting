#!/usr/bin/env python3
"""chaoting CLI — agent interface to the chaoting task orchestration system."""

import json
import os
import sqlite3
import subprocess
import sys
from datetime import datetime, timezone

CHAOTING_DIR = os.environ.get("CHAOTING_DIR", os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

# Load .env from project root (does not override existing env vars)
_dotenv_path = os.path.join(CHAOTING_DIR, ".env")
if os.path.isfile(_dotenv_path):
    with open(_dotenv_path) as _f:
        for _line in _f:
            _line = _line.strip()
            if _line and not _line.startswith("#") and "=" in _line:
                _k, _, _v = _line.partition("=")
                if _k.strip() not in os.environ:
                    os.environ[_k.strip()] = _v.strip()

DB_PATH = os.path.join(CHAOTING_DIR, "chaoting.db")
OPENCLAW_CLI = os.environ.get("OPENCLAW_CLI", "themachine")

# Shared audit log module
_src_dir = os.path.dirname(os.path.abspath(__file__))
if _src_dir not in sys.path:
    sys.path.insert(0, _src_dir)
from chaoting_log import zouzhe_log  # noqa: E402


def get_db():
    db = sqlite3.connect(DB_PATH, timeout=30)
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode=WAL")
    db.execute("PRAGMA busy_timeout=5000")
    return db


DISCORD_FALLBACK_CHANNEL_ID = os.environ.get("DISCORD_FALLBACK_CHANNEL_ID", "")


def _send_discord_thread(thread_id: str, body: str) -> bool:
    """Send a message to a Discord Thread. Returns True on success."""
    try:
        result = subprocess.run(
            [OPENCLAW_CLI, "message", "thread", "reply",
             "--channel", "discord", "-t", thread_id, "-m", body[:2000]],
            timeout=30,
            capture_output=True,
            check=False,
        )
        return result.returncode == 0
    except Exception as exc:
        print(f"[WARN] discord thread send failed: {exc}", file=sys.stderr)
        return False


def _send_discord_channel(channel_id: str, body: str) -> bool:
    """Send a message to a Discord channel. Returns True on success."""
    try:
        result = subprocess.run(
            [OPENCLAW_CLI, "message", "send",
             "--channel", "discord",
             "--target", channel_id,
             "--message", body[:2000]],
            timeout=30,
            capture_output=True,
            check=False,
        )
        return result.returncode == 0
    except Exception as exc:
        print(f"[WARN] discord channel send failed: {exc}", file=sys.stderr)
        return False


def send_discord(zouzhe_id: str, body: str, thread_id: str = None) -> bool:
    """Send a Discord notification: thread if available, otherwise fallback channel.

    If thread_id is not provided, looks it up from the zouzhe record.
    Returns True if sent successfully, False otherwise. Never raises.
    """
    # Resolve thread_id from DB if not provided
    if thread_id is None:
        try:
            db = get_db()
            row = db.execute(
                "SELECT discord_thread_id FROM zouzhe WHERE id = ?", (zouzhe_id,)
            ).fetchone()
            db.close()
            if row and row["discord_thread_id"]:
                thread_id = row["discord_thread_id"]
        except Exception:
            pass

    if thread_id:
        return _send_discord_thread(thread_id, body)

    if DISCORD_FALLBACK_CHANNEL_ID:
        return _send_discord_channel(DISCORD_FALLBACK_CHANNEL_ID, body)

    print(f"[WARN] no thread_id and DISCORD_FALLBACK_CHANNEL_ID not set — "
          f"notification dropped for {zouzhe_id}", file=sys.stderr)
    return False




def _dept_prefix(agent: str) -> str:
    """Return the department prefix for Thread messages per POLICY-thread-format.md."""
    _MAP = {
        "bingbu": "【兵部】⚔️",
        "gongbu": "【工部】🔧",
        "hubu":   "【户部】💼",
        "libu":   "【吏部】👥",
        "libu_hr":"【吏部】👥",
        "libu_data":"【户部】💼",
        "xingbu": "【刑部】⚖️",
        "libu_rites":"【礼部】🎖️",
        "zhongshu":"【中书省】📝",
        "menxia": "【门下省】🏛️",
        "silijian":"【司礼监】🏛️",
        "jishi_tech": "【技术给事中】🔍",
        "jishi_risk": "【风险给事中】⚠️",
        "jishi_resource": "【资源给事中】💰",
        "jishi_compliance": "【合规给事中】✔️",
    }
    return _MAP.get(agent, f"【{agent}】")


def _fmt_done_thread(zid: str, agent: str, output: str, summary: str) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    prefix = _dept_prefix(agent)
    out_lines = (output or "").strip()[:600]
    return (
        f"{prefix} 任务完成\n\n"
        f"奏折：`{zid}`\n"
        f"完成时间：{ts}\n\n"
        f"**【工作内容】**\n{out_lines}\n\n"
        f"**【输出概述】**\n{summary or '(无摘要)'}\n\n"
        f"如有问题，请在此 Thread 中讨论。"
    )


def _fmt_fail_thread(zid: str, agent: str, reason: str) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    prefix = _dept_prefix(agent)
    return (
        f"{prefix} 任务失败\n\n"
        f"奏折：`{zid}`\n"
        f"失败时间：{ts}\n\n"
        f"**【失败原因】**\n{reason or '(未说明)'}\n\n"
        f"请在此 Thread 中讨论处理方案。"
    )


def _fmt_plan_thread(zid: str, target_agent: str, next_state: str, plan_raw: str = None) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    if next_state == "reviewing":
        action = "计划已提交，进入门下省审核"
        detail = f"• 负责部门：{target_agent}\n• 下一状态：reviewing（等待给事中投票）"
    else:
        action = "计划已提交，直接进入执行（免审）"
        detail = f"• 负责部门：{target_agent}\n• 下一状态：executing"
    plan_section = ""
    if plan_raw:
        try:
            plan = json.loads(plan_raw)
            parts = []
            if plan.get("steps"):
                steps_text = "\n".join(f"  {i+1}. {s}" for i, s in enumerate(plan["steps"]))
                parts.append(f"**执行步骤：**\n{steps_text}")
            if plan.get("acceptance_criteria"):
                parts.append(f"**验收标准：** {plan['acceptance_criteria']}")
            if parts:
                plan_section = "\n\n" + "\n".join(parts)
        except (json.JSONDecodeError, TypeError):
            pass
    return (
        f"【中书省】📝 规划方案已提出\n\n"
        f"奏折：`{zid}`\n"
        f"提交时间：{ts}\n\n"
        f"{action}\n{detail}{plan_section}"
    )


def _fmt_vote_thread(zid: str, jishi_id: str, vote: str, reason: str, round_num: int) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    prefix = _dept_prefix(jishi_id)
    symbol = "GO ✅" if vote == "go" else "NOGO ❌"
    reason_line = f"\n\n**【审查意见】**\n{reason}" if reason else ""
    return (
        f"{prefix} 审查完成\n\n"
        f"奏折：`{zid}`\n"
        f"投票：{symbol}\n"
        f"轮次：第 {round_num} 轮\n"
        f"时间：{ts}"
        f"{reason_line}"
    )


def _fmt_revise_thread(zid: str, caller: str, reason: str, count: int, target_state: str) -> str:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    target_label = "重新规划（revising）" if target_state == "revising" else "重新执行（executing）"
    prefix = _dept_prefix(caller)
    return (
        f"{prefix} 奏折退回返工\n\n"
        f"奏折：`{zid}`\n"
        f"第 {count} 次返工 → {target_label}\n"
        f"时间：{ts}\n\n"
        f"**【返工原因】**\n{reason}"
    )

def out(data, ok=True):
    code = 0 if ok else 1
    print(json.dumps(data, ensure_ascii=False))
    sys.exit(code)


def cmd_new(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting new '<title>' ['<description>'] [--review N] [--priority normal|critical] [--timeout 600] [--thread-id DISCORD_THREAD_ID]"}, ok=False)

    title = args[0]

    # description is optional positional arg (before any -- flags)
    description = ""
    idx_start = 1
    if len(args) > 1 and not args[1].startswith("--"):
        description = args[1]
        idx_start = 2

    # Parse optional flags
    review_required = 2  # default: tech + risk review
    priority = "normal"
    timeout_sec = 600
    discord_thread_id = None

    i = idx_start
    while i < len(args):
        if args[i] == "--review" and i + 1 < len(args):
            try:
                review_required = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--review must be an integer (0-3)"}, ok=False)
            i += 2
        elif args[i] == "--priority" and i + 1 < len(args):
            priority = args[i + 1]
            i += 2
        elif args[i] == "--timeout" and i + 1 < len(args):
            try:
                timeout_sec = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--timeout must be an integer"}, ok=False)
            i += 2
        elif args[i] == "--thread-id" and i + 1 < len(args):
            discord_thread_id = args[i + 1]
            i += 2
        else:
            i += 1

    today = datetime.now(timezone.utc).strftime("%Y%m%d")
    prefix = f"ZZ-{today}-"

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        # Concurrency-safe ID generation via MAX in transaction
        row = db.execute(
            "SELECT MAX(id) AS max_id FROM zouzhe WHERE id LIKE ?",
            (f"{prefix}%",),
        ).fetchone()

        if row["max_id"]:
            last_num = int(row["max_id"][-3:])
            next_num = last_num + 1
        else:
            next_num = 1

        new_id = f"{prefix}{next_num:03d}"

        # Validate discord_thread_id uniqueness: prevent two active zouzhe from sharing a thread
        if discord_thread_id:
            conflict = db.execute(
                "SELECT id FROM zouzhe WHERE discord_thread_id = ? "
                "AND state NOT IN ('done', 'failed', 'timeout')",
                (discord_thread_id,),
            ).fetchone()
            if conflict:
                db.execute("ROLLBACK")
                db.close()
                out({
                    "ok": False,
                    "error": f"discord_thread_id {discord_thread_id} is already used by active zouzhe {conflict['id']}. "
                             f"Each active zouzhe must have a unique thread."
                }, ok=False)

        db.execute(
            "INSERT INTO zouzhe "
            "(id, title, description, state, priority, timeout_sec, review_required, revise_count, discord_thread_id) "
            "VALUES (?, ?, ?, 'created', ?, ?, ?, 0, ?)",
            (new_id, title, description, priority, timeout_sec, review_required, discord_thread_id),
        )

        db.execute("COMMIT")
        db.close()

        # Audit log: record creation in caller's log file
        caller = os.environ.get("OPENCLAW_AGENT_ID", "silijian")
        zouzhe_log(new_id, caller, "CREATED",
                   f"奏折已创建：{title}",
                   priority=priority,
                   review_required=review_required,
                   timeout_sec=timeout_sec)

        # Discord notification for task creation
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        send_discord(
            new_id,
            f"🏛️ **奏折已创建**\n\n奏折：{new_id}\n标题：{title}\n优先级：{priority}\n"
            f"审核级别：{review_required}\n创建时间：{ts}\n\n等待中书省规划方案……",
            thread_id=discord_thread_id,
        )

        out({"ok": True, "id": new_id, "state": "created", "discord_thread_id": discord_thread_id})
    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_list(args):
    state_filter = None
    limit = 20

    i = 0
    while i < len(args):
        if args[i] == "--state" and i + 1 < len(args):
            state_filter = args[i + 1]
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            try:
                limit = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--limit must be an integer"}, ok=False)
            i += 2
        else:
            i += 1

    db = get_db()
    if state_filter:
        rows = db.execute(
            "SELECT id, title, state, assigned_agent, created_at FROM zouzhe "
            "WHERE state = ? ORDER BY created_at DESC LIMIT ?",
            (state_filter, limit),
        ).fetchall()
    else:
        rows = db.execute(
            "SELECT id, title, state, assigned_agent, created_at FROM zouzhe "
            "ORDER BY created_at DESC LIMIT ?",
            (limit,),
        ).fetchall()

    result = [dict(r) for r in rows]
    db.close()
    out({"ok": True, "zouzhe": result, "count": len(result)})


