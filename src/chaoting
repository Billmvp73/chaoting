#!/usr/bin/env python3
"""chaoting CLI — agent interface to the chaoting task orchestration system."""

import json
import os
import sqlite3
import sys
from datetime import datetime, timezone

CHAOTING_DIR = os.environ.get("CHAOTING_DIR", os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
DB_PATH = os.path.join(CHAOTING_DIR, "chaoting.db")


def get_db():
    db = sqlite3.connect(DB_PATH, timeout=30)
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode=WAL")
    db.execute("PRAGMA busy_timeout=5000")
    return db


def out(data, ok=True):
    code = 0 if ok else 1
    print(json.dumps(data, ensure_ascii=False))
    sys.exit(code)


def cmd_new(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting new '<title>' ['<description>'] [--review N] [--priority normal|critical] [--timeout 600]"}, ok=False)

    title = args[0]

    # description is optional positional arg (before any -- flags)
    description = ""
    idx_start = 1
    if len(args) > 1 and not args[1].startswith("--"):
        description = args[1]
        idx_start = 2

    # Parse optional flags
    review_required = 2  # default: tech + risk review
    priority = "normal"
    timeout_sec = 600

    i = idx_start
    while i < len(args):
        if args[i] == "--review" and i + 1 < len(args):
            try:
                review_required = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--review must be an integer (0-3)"}, ok=False)
            i += 2
        elif args[i] == "--priority" and i + 1 < len(args):
            priority = args[i + 1]
            i += 2
        elif args[i] == "--timeout" and i + 1 < len(args):
            try:
                timeout_sec = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--timeout must be an integer"}, ok=False)
            i += 2
        else:
            i += 1

    today = datetime.now(timezone.utc).strftime("%Y%m%d")
    prefix = f"ZZ-{today}-"

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        # Concurrency-safe ID generation via MAX in transaction
        row = db.execute(
            "SELECT MAX(id) AS max_id FROM zouzhe WHERE id LIKE ?",
            (f"{prefix}%",),
        ).fetchone()

        if row["max_id"]:
            last_num = int(row["max_id"][-3:])
            next_num = last_num + 1
        else:
            next_num = 1

        new_id = f"{prefix}{next_num:03d}"

        db.execute(
            "INSERT INTO zouzhe "
            "(id, title, description, state, priority, timeout_sec, review_required, revise_count) "
            "VALUES (?, ?, ?, 'created', ?, ?, ?, 0)",
            (new_id, title, description, priority, timeout_sec, review_required),
        )

        db.execute("COMMIT")
        db.close()
        out({"ok": True, "id": new_id, "state": "created"})
    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


def cmd_list(args):
    state_filter = None
    limit = 20

    i = 0
    while i < len(args):
        if args[i] == "--state" and i + 1 < len(args):
            state_filter = args[i + 1]
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            try:
                limit = int(args[i + 1])
            except ValueError:
                out({"ok": False, "error": "--limit must be an integer"}, ok=False)
            i += 2
        else:
            i += 1

    db = get_db()
    if state_filter:
        rows = db.execute(
            "SELECT id, title, state, assigned_agent, created_at FROM zouzhe "
            "WHERE state = ? ORDER BY created_at DESC LIMIT ?",
            (state_filter, limit),
        ).fetchall()
    else:
        rows = db.execute(
            "SELECT id, title, state, assigned_agent, created_at FROM zouzhe "
            "ORDER BY created_at DESC LIMIT ?",
            (limit,),
        ).fetchall()

    result = [dict(r) for r in rows]
    db.close()
    out({"ok": True, "zouzhe": result, "count": len(result)})


def cmd_status(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting status <zouzhe_id>"}, ok=False)

    zid = args[0]
    db = get_db()

    row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    zouzhe = dict(row)
    if zouzhe.get("plan"):
        try:
            zouzhe["plan"] = json.loads(zouzhe["plan"])
        except Exception:
            pass

    toupiao = [
        {
            "id": r["id"],
            "round": r["round"],
            "jishi_id": r["jishi_id"],
            "agent_id": r["agent_id"],
            "vote": r["vote"],
            "reason": r["reason"],
            "timestamp": r["timestamp"],
        }
        for r in db.execute(
            "SELECT * FROM toupiao WHERE zouzhe_id = ? ORDER BY round, id",
            (zid,),
        ).fetchall()
    ]

    liuzhuan = [
        {
            "id": r["id"],
            "from_role": r["from_role"],
            "to_role": r["to_role"],
            "action": r["action"],
            "remark": r["remark"],
            "timestamp": r["timestamp"],
        }
        for r in db.execute(
            "SELECT * FROM liuzhuan WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    zoubao = [
        {
            "id": r["id"],
            "agent_id": r["agent_id"],
            "text": r["text"],
            "timestamp": r["timestamp"],
        }
        for r in db.execute(
            "SELECT * FROM zoubao WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    db.close()
    out({
        "ok": True,
        "zouzhe": zouzhe,
        "toupiao": toupiao,
        "liuzhuan": liuzhuan,
        "zoubao": zoubao,
    })


def cmd_pull(args):
    if len(args) < 1:
        out({"ok": False, "error": "usage: chaoting pull <zouzhe_id>"}, ok=False)

    zid = args[0]
    db = get_db()

    row = db.execute("SELECT * FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    zouzhe = {
        "id": row["id"],
        "title": row["title"],
        "description": row["description"],
        "state": row["state"],
        "priority": row["priority"],
        "plan": json.loads(row["plan"]) if row["plan"] else None,
    }

    dianji = [
        {"key": r["context_key"], "value": r["context_value"], "confidence": r["confidence"]}
        for r in db.execute(
            "SELECT context_key, context_value, confidence FROM dianji "
            "WHERE agent_role = ?", (row["assigned_agent"],)
        ).fetchall()
    ]

    qianche = [
        r["lesson"]
        for r in db.execute(
            "SELECT lesson FROM qianche WHERE agent_role = ? OR zouzhe_id = ?",
            (row["assigned_agent"], zid),
        ).fetchall()
    ]

    liuzhuan = [
        {"from": r["from_role"], "to": r["to_role"], "action": r["action"], "remark": r["remark"]}
        for r in db.execute(
            "SELECT from_role, to_role, action, remark FROM liuzhuan WHERE zouzhe_id = ? ORDER BY id",
            (zid,),
        ).fetchall()
    ]

    db.close()
    out({"ok": True, "zouzhe": zouzhe, "dianji": dianji, "qianche": qianche, "liuzhuan": liuzhuan})


def cmd_plan(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting plan <zouzhe_id> '<plan_json>'"}, ok=False)

    zid = args[0]
    plan_raw = args[1]

    try:
        plan = json.loads(plan_raw)
    except json.JSONDecodeError as e:
        out({"ok": False, "error": f"invalid plan JSON: {e}"}, ok=False)

    target_agent = plan.get("target_agent")
    if not target_agent:
        out({"ok": False, "error": "plan must include target_agent"}, ok=False)

    db = get_db()

    # Check if review is required
    zouzhe = db.execute(
        "SELECT id, review_required FROM zouzhe WHERE id = ? AND state = 'planning'",
        (zid,),
    ).fetchone()
    if not zouzhe:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in planning state"}, ok=False)

    if zouzhe["review_required"]:
        # Enter reviewing state — dispatcher will dispatch to 给事中
        cursor = db.execute(
            "UPDATE zouzhe SET state = 'reviewing', plan = ?, assigned_agent = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'planning' RETURNING id",
            (plan_raw, target_agent, zid),
        )
        row = cursor.fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": "state conflict — CAS failed"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, 'zhongshu', 'menxia', 'submit_review', ?)",
            (zid, "planning complete, entering review"),
        )
        db.commit()
        db.close()
        out({"ok": True, "zouzhe_id": zid, "state": "reviewing", "target_agent": target_agent})
    else:
        # Skip review — go directly to executing
        cursor = db.execute(
            "UPDATE zouzhe SET state = 'executing', plan = ?, assigned_agent = ?, "
            "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
            "WHERE id = ? AND state = 'planning' RETURNING id",
            (plan_raw, target_agent, zid),
        )
        row = cursor.fetchone()
        if not row:
            db.close()
            out({"ok": False, "error": "state conflict — CAS failed"}, ok=False)

        db.execute(
            "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
            "VALUES (?, 'zhongshu', ?, 'complete', ?)",
            (zid, target_agent, "planning complete, dispatching to agent"),
        )
        db.commit()
        db.close()
        out({"ok": True, "zouzhe_id": zid, "state": "executing", "target_agent": target_agent})


def cmd_progress(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting progress <zouzhe_id> '<text>'"}, ok=False)

    zid = args[0]
    text = args[1]

    db = get_db()
    row = db.execute("SELECT id FROM zouzhe WHERE id = ?", (zid,)).fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": f"zouzhe {zid} not found"}, ok=False)

    db.execute(
        "INSERT INTO zoubao (zouzhe_id, agent_id, text) VALUES (?, ?, ?)",
        (zid, None, text),
    )
    db.execute(
        "UPDATE zouzhe SET updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') WHERE id = ?",
        (zid,),
    )
    db.commit()
    db.close()
    out({"ok": True, "zouzhe_id": zid, "action": "progress"})


def cmd_done(args):
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting done <zouzhe_id> '<output>' '<summary>'"}, ok=False)

    zid = args[0]
    output = args[1]
    summary = args[2]

    db = get_db()
    cursor = db.execute(
        "UPDATE zouzhe SET state = 'done', output = ?, summary = ?, "
        "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
        "WHERE id = ? AND state = 'executing' RETURNING id",
        (output, summary, zid),
    )
    row = cursor.fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in executing state"}, ok=False)

    db.execute(
        "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
        "VALUES (?, ?, 'dispatcher', 'complete', ?)",
        (zid, db.execute("SELECT assigned_agent FROM zouzhe WHERE id = ?", (zid,)).fetchone()["assigned_agent"],
         summary),
    )
    db.commit()
    db.close()
    out({"ok": True, "zouzhe_id": zid, "state": "done"})


def cmd_fail(args):
    if len(args) < 2:
        out({"ok": False, "error": "usage: chaoting fail <zouzhe_id> '<reason>'"}, ok=False)

    zid = args[0]
    reason = args[1]

    db = get_db()
    cursor = db.execute(
        "UPDATE zouzhe SET state = 'failed', error = ?, "
        "dispatched_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%S','now') "
        "WHERE id = ? AND state IN ('planning', 'executing') RETURNING id",
        (reason, zid),
    )
    row = cursor.fetchone()
    if not row:
        db.close()
        out({"ok": False, "error": "state conflict — zouzhe not in active state"}, ok=False)

    db.execute(
        "INSERT INTO liuzhuan (zouzhe_id, from_role, to_role, action, remark) "
        "VALUES (?, ?, 'dispatcher', 'fail', ?)",
        (zid, db.execute("SELECT assigned_agent FROM zouzhe WHERE id = ?", (zid,)).fetchone()["assigned_agent"],
         reason),
    )
    db.commit()
    db.close()
    out({"ok": True, "zouzhe_id": zid, "state": "failed"})


def cmd_context(args):
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting context <agent_role> <key> <value> [--source ZZ-...]"}, ok=False)

    agent_role = args[0]
    key = args[1]
    value = args[2]
    source = None
    if "--source" in args:
        idx = args.index("--source")
        if idx + 1 < len(args):
            source = args[idx + 1]

    db = get_db()
    db.execute(
        "INSERT INTO dianji (agent_role, context_key, context_value, source, updated_at) "
        "VALUES (?, ?, ?, ?, strftime('%Y-%m-%dT%H:%M:%S','now')) "
        "ON CONFLICT(agent_role, context_key) DO UPDATE SET "
        "context_value = excluded.context_value, source = excluded.source, "
        "confidence = 'fresh', updated_at = strftime('%Y-%m-%dT%H:%M:%S','now')",
        (agent_role, key, value, source),
    )
    db.commit()
    db.close()
    out({"ok": True, "agent_role": agent_role, "context_key": key})


def cmd_vote(args):
    # Parse: chaoting vote ZZ-xxx go/nogo 'reason' --as jishi_tech
    if len(args) < 3:
        out({"ok": False, "error": "usage: chaoting vote <zouzhe_id> <go|nogo> '<reason>' --as <jishi_id>"}, ok=False)

    zid = args[0]
    vote = args[1]
    reason = args[2] if len(args) > 2 else ""

    if vote not in ("go", "nogo"):
        out({"ok": False, "error": "vote must be 'go' or 'nogo'"}, ok=False)

    # Parse --as parameter
    jishi_id = None
    if "--as" in args:
        idx = args.index("--as")
        if idx + 1 < len(args):
            jishi_id = args[idx + 1]
    if not jishi_id:
        out({"ok": False, "error": "--as <jishi_id> is required"}, ok=False)

    agent_id = os.environ.get("OPENCLAW_AGENT_ID", "unknown")

    db = get_db()
    try:
        db.execute("BEGIN IMMEDIATE")

        zouzhe = db.execute(
            "SELECT id, revise_count FROM zouzhe WHERE id = ? AND state = 'reviewing'",
            (zid,),
        ).fetchone()

        if not zouzhe:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "zouzhe not in reviewing state"}, ok=False)

        current_round = (zouzhe["revise_count"] or 0) + 1

        cursor = db.execute(
            "INSERT OR IGNORE INTO toupiao (zouzhe_id, round, jishi_id, agent_id, vote, reason) "
            "VALUES (?, ?, ?, ?, ?, ?)",
            (zid, current_round, jishi_id, agent_id, vote, reason),
        )

        if cursor.rowcount == 0:
            db.execute("ROLLBACK")
            db.close()
            out({"ok": False, "error": "already voted this round"}, ok=False)

        db.execute("COMMIT")
        db.close()
        out({"ok": True, "action": "vote", "zouzhe_id": zid, "vote": vote,
             "jishi_id": jishi_id, "round": current_round})
    except Exception as e:
        try:
            db.execute("ROLLBACK")
        except Exception:
            pass
        db.close()
        out({"ok": False, "error": str(e)}, ok=False)


COMMANDS = {
    "new": cmd_new,
    "list": cmd_list,
    "status": cmd_status,
    "pull": cmd_pull,
    "plan": cmd_plan,
    "progress": cmd_progress,
    "done": cmd_done,
    "fail": cmd_fail,
    "context": cmd_context,
    "vote": cmd_vote,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        cmds = ", ".join(COMMANDS.keys())
        out({"ok": False, "error": f"usage: chaoting <{cmds}> [args...]"}, ok=False)

    cmd = sys.argv[1]
    COMMANDS[cmd](sys.argv[2:])


if __name__ == "__main__":
    main()
